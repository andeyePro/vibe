#!/bin/bash
# vibe — single-command containerised YOLO Claude Code sessions
# https://github.com/Aqueum/vibe
#
# Usage:
#   vibe                     # cd to your project folder, then just run this
#   vibe <project-name>      # launch by name from anywhere (uses VIBE_PROJECTS_DIR)
#   vibe --rebuild           # force rebuild of the vibe container image
#   vibe --continue          # resume the most recent Claude conversation in this dir
#   vibe --resume            # interactively pick a Claude conversation to resume
#   vibe --resume <uuid>     # resume a specific Claude conversation by id
#   vibe --fable             # launch on Claude Fable 5 (frontier model; billing-aware)
#   vibe --model <id>        # launch on a specific Claude model id
#   vibe --list              # list available projects
#   vibe --version           # print the vibe version and exit
#   vibe --help              # show this help
#
# Flags and the project name can appear in any order, so e.g.
#   vibe vibe --continue
#   vibe --continue vibe
# both resume the most recent conversation in the `vibe` project.
#   vibe learn "<pattern>"   # save a cross-project pattern to your learning library
#   vibe learn --init        # set up the learning library (one-time opt-in)
#   vibe learn --exclude     # opt this project out of learning (creates .no-learn)
#   vibe learn --include     # opt this project back in (removes .no-learn)
#
# All `vibe learn` subcommands run on the HOST shell, from the project
# directory. They are not available inside the container — the launcher
# is a host binary and the per-project .no-learn marker is written to
# the bind-mounted project tree from outside.
#
# Note: --continue and --resume are opt-in. Default is fresh — the durable
# handover lives in TODO.md, CLAUDE.md, and Claude's auto-memory, not in
# resumed conversations (which accumulate compaction debt over weeks).
#
# Model selection: --fable / --model apply per-launch (they do not change the
# model Claude Code has persisted as your default). A default can be set in
# ~/.vibe/config with VIBE_MODEL="claude-fable-5"; flags win over config.
# Fable 5 is included in Pro/Max subscriptions until 7 Jul 2026; from 8 Jul
# it bills usage credits at API rates, so vibe asks before launching it then
# (skip the ask with VIBE_FABLE_CREDITS_OK=1 in ~/.vibe/config).

set -euo pipefail

# ── Configuration ─────────────────────────────────────────────────────────────
CONFIG_FILE="${VIBE_CONFIG:-$HOME/.vibe/config}"
TOKENS_FILE="$HOME/.vibe/tokens"
# Machine-local registry of shared-repo checkouts (task_017): `slug=path`
# lines, chmod 600 like TOKENS_FILE. Distinct file from TOKENS_FILE because
# it maps a slug to a LOCAL PATH, not a secret — no reason to share the
# tighter secret-store mental model, and keeping them separate means a
# `grep` of one never accidentally surfaces the other.
REPOS_REGISTRY_FILE="$HOME/.vibe/repos"
SKIPPED_FILE="$HOME/.vibe/skipped"
IMAGE_MARKER="$HOME/.vibe/.image-built"
IMAGE_TAG="vibe-dev:latest"
# Loopback port for the OpenProject MCP forwarder (Mac-side TCP passthrough to
# the tailnet-only sidecar). Single source of truth: exported to the container
# as OPENPROJECT_MCP_FWD_PORT so register-op-mcp.sh builds the matching URL.
OP_MCP_FWD_PORT=18443

# Resolve DEVCONTAINER_DIR from this script's real location, following symlinks.
# ~/bin/vibe is a symlink that install.sh points at either ~/.vibe-src (curl
# installs) or a developer's in-place clone. Reading devcontainer/ from next to
# the resolved script means both modes work and `rm -rf ~/.vibe-src` is safe
# once a dev clone is in use.
_vibe_src="${BASH_SOURCE[0]:-$0}"
while [ -L "$_vibe_src" ]; do
  _vibe_dir="$(cd "$(dirname "$_vibe_src")" && pwd -P)"
  _vibe_src="$(readlink "$_vibe_src")"
  [[ "$_vibe_src" != /* ]] && _vibe_src="$_vibe_dir/$_vibe_src"
done
DEVCONTAINER_DIR="$(cd "$(dirname "$_vibe_src")" && pwd -P)/devcontainer"
unset _vibe_src _vibe_dir
VIBE_REPO_DIR="$(dirname "$DEVCONTAINER_DIR")"

if [ -f "$CONFIG_FILE" ]; then
  # shellcheck source=/dev/null
  source "$CONFIG_FILE"
fi

PROJECTS_DIR="${VIBE_PROJECTS_DIR:-$HOME/Projects}"

# Re-export config vars that need to reach the container via ${localEnv:NAME}
# in devcontainer.json. `source` makes plain assignments visible in this shell
# but not in subprocesses unless explicitly exported. This lets users write
# `VIBE_SSH_AUTO=1` (without `export`) in ~/.vibe/config and have it work.
export VIBE_SSH_AUTO="${VIBE_SSH_AUTO:-}"

# ── Helpers ───────────────────────────────────────────────────────────────────
# Version string. Read from the VERSION file next to the resolved script
# (VIBE_REPO_DIR is derived from the script's realpath, so this works whether
# vibe is invoked via the ~/bin/vibe symlink or an in-place dev clone, and from
# any project directory). Missing/empty VERSION → 0.0.0-dev, never an error.
_vibe_version() {
  local vfile="$VIBE_REPO_DIR/VERSION" ver=""
  [ -f "$vfile" ] && ver="$(head -n1 "$vfile" | tr -d '[:space:]')"
  echo "${ver:-0.0.0-dev}"
}

print_version() {
  echo "vibe $(_vibe_version)"
  exit 0
}

usage() {
  grep '^#' "$0" | grep -v '#!/' | sed 's/^# \?//'
  echo ""
  echo "vibe $(_vibe_version)"
  exit 0
}

require() {
  if ! command -v "$1" &>/dev/null; then
    echo "  ✗ '$1' not found. $2"
    exit 1
  fi
}

# Portable lowercase — avoids ${var,,} which requires bash 4+ (macOS ships bash 3.2)
lowercase() {
  tr '[:upper:]' '[:lower:]' <<< "$1"
}

# Three-way prompt: prints "yes", "no", or "never"
ask_yes_no_never() {
  local prompt="$1"
  local reply reply_lc
  while true; do
    read -rp "  $prompt [Y/n/never]: " reply
    reply="${reply:-y}"
    reply_lc=$(lowercase "$reply")
    case "$reply_lc" in
      y|yes)   echo "yes";   return ;;
      n|no)    echo "no";    return ;;
      never)   echo "never"; return ;;
      *) echo "  Please answer y, n, or never." ;;
    esac
  done
}

ask_yes_no() {
  local prompt="$1" default="${2:-y}"
  local options reply reply_lc
  [ "$default" = "n" ] && options="y/N" || options="Y/n"
  read -rp "  $prompt [$options]: " reply
  reply="${reply:-$default}"
  reply_lc=$(lowercase "$reply")
  [ "$reply_lc" = "y" ]
}

# ── Git helpers ───────────────────────────────────────────────────────────────

detect_github_repo() {
  local url
  url=$(git remote get-url origin 2>/dev/null) || return 1
  if [[ "$url" =~ github\.com[:/]([^/]+/[^/.]+)(\.git)?$ ]]; then
    echo "${BASH_REMATCH[1]}"
    return 0
  fi
  return 1
}

# Canonical form of $WORKSPACE: trailing-slash stripped, symlinks resolved.
# Falls back to a slash-stripped literal if cd fails (e.g. dir gone). Used
# by both mark and check so a project marked "never" stays marked even when
# the user reaches it via a different symlink path or with a trailing slash.
_canonical_workspace() {
  local p="${WORKSPACE%/}"
  [ -z "$p" ] && p="$WORKSPACE"
  (cd "$p" 2>/dev/null && pwd -P) || echo "$p"
}

is_github_skipped() {
  [ -f "$SKIPPED_FILE" ] || return 1
  local canon
  canon="$(_canonical_workspace)"
  # Match either the literal current $WORKSPACE (back-compat with entries
  # written before canonicalisation) or its canonical form.
  grep -qxF "$WORKSPACE" "$SKIPPED_FILE" && return 0
  [ "$canon" != "$WORKSPACE" ] && grep -qxF "$canon" "$SKIPPED_FILE"
}

mark_github_skipped() {
  mkdir -p "$(dirname "$SKIPPED_FILE")"
  _canonical_workspace >> "$SKIPPED_FILE"
  echo "  ✓ Got it — won't ask about GitHub for this project again."
}

ensure_initial_commit() {
  if ! git rev-parse --git-dir &>/dev/null; then
    echo "  Initialising git repository..."
    git init
  fi
  if ! git rev-parse HEAD &>/dev/null 2>&1; then
    git add -A 2>/dev/null || true
    git commit --allow-empty -m "Initial commit" 2>/dev/null || true
    echo "  ✓ Initial commit created."
  fi
}

# Default owner for a new repo: VIBE_GITHUB_OWNER from ~/.vibe/config wins,
# else the logged-in gh user ($1).
default_repo_owner() {
  if [ -n "${VIBE_GITHUB_OWNER:-}" ]; then
    echo "$VIBE_GITHUB_OWNER"
  else
    echo "$1"
  fi
}

# True if <owner> exists on GitHub. The /users/ endpoint resolves both user
# accounts and orgs, so one check covers either kind of owner.
owner_exists_on_github() {
  gh api "users/$1" --jq '.login' >/dev/null 2>&1
}

# Prompt for the owner (personal account or org) a new repo goes under.
# Echoes the chosen owner. A short org hint is shown when the user belongs
# to any (informational — a full picker is unwieldy for many-org accounts).
# Typo'd owners are caught by an existence check with re-prompt; after 3
# misses the user may proceed unvalidated, since the check itself can fail
# on a blocked network while the name is actually fine.
choose_repo_owner() {
  local gh_user="$1" owner_default owner orgs attempts=0

  orgs=$(gh api user/orgs --jq '.[].login' 2>/dev/null | head -8 | paste -sd ', ' -) || orgs=""
  [ -n "$orgs" ] && echo "  Your orgs: $orgs" >&2

  owner_default=$(default_repo_owner "$gh_user")
  while :; do
    read -rp "  Owner (account or org) [$owner_default]: " owner
    owner="${owner:-$owner_default}"
    if [ "$owner" = "$gh_user" ] || owner_exists_on_github "$owner"; then
      break
    fi
    attempts=$((attempts + 1))
    if [ "$attempts" -ge 3 ]; then
      if ask_yes_no "Proceed with '$owner' unvalidated? (the check may be failing, not the name)" n; then
        break
      fi
      attempts=0
    else
      echo "  ✗ '$owner' not found on GitHub — check the spelling and try again." >&2
    fi
  done

  if [ "$owner" != "$owner_default" ]; then
    echo "  Tip: VIBE_GITHUB_OWNER=\"$owner\" in ~/.vibe/config makes this the default." >&2
  fi
  echo "$owner"
}

create_github_repo() {
  echo ""
  echo "  No GitHub repo found for this project."
  echo ""

  local answer
  answer=$(ask_yes_no_never "Create a GitHub repo for it?")

  case "$answer" in
    never) mark_github_skipped; return ;;
    no)    echo "  Skipping — launching without GitHub."; return ;;
  esac

  local gh_user
  gh_user=$(gh api user --jq '.login' 2>/dev/null) || {
    echo "  ✗ Not logged in to GitHub CLI. Run: gh auth login"
    return
  }

  local repo_name
  read -rp "  Repo name [$PROJECT_NAME]: " repo_name
  repo_name="${repo_name:-$PROJECT_NAME}"

  local owner
  owner=$(choose_repo_owner "$gh_user")

  local visibility="private"
  ask_yes_no "Make it public?" n && visibility="public"

  local description=""
  read -rp "  Description (optional): " description

  ensure_initial_commit

  local full_name="$owner/$repo_name"
  echo "  Creating $visibility repo $full_name on GitHub..."

  local create_args=("$full_name" "--$visibility" "--source=." "--push")
  [ -n "$description" ] && create_args+=("--description=$description")

  if gh repo create "${create_args[@]}"; then
    GITHUB_REPO="$full_name"
    echo "  ✓ Repo created: https://github.com/$GITHUB_REPO"
  else
    echo "  ✗ Repo creation failed — launching without GitHub."
    if [ "$owner" != "$gh_user" ]; then
      echo "    If '$owner' is an org, check you have repo-creation permission there."
    fi
  fi
}

# ── Token helpers ─────────────────────────────────────────────────────────────

lookup_token() {
  local repo="$1"
  [ -f "$TOKENS_FILE" ] || return 0
  # `-f2-` (not `-f2`) so a value containing `=` (e.g. a base64 bearer with
  # padding) is returned whole, not truncated at the first `=`. Keys never
  # contain `=`, so splitting on the first `=` still isolates the value.
  # index()==1 is a FIXED-STRING prefix match — never treat the key as a
  # regex: `.` is in the slug charset and a committed .vibe-repos line like
  # `myor./secret` must not BRE-match a different registered `myorg/secret`
  # entry (security-review finding, task_017 C1).
  awk -v k="${repo}" 'index($0, k"=")==1 {print substr($0, length(k)+2)}' "$TOKENS_FILE" 2>/dev/null || true
}

save_token() {
  local repo="$1" token="$2"
  mkdir -p "$(dirname "$TOKENS_FILE")"
  touch "$TOKENS_FILE"
  local tmp
  tmp=$(mktemp)
  awk -v k="${repo}" 'index($0, k"=")!=1' "$TOKENS_FILE" > "$tmp" || true
  echo "${repo}=${token}" >> "$tmp"
  mv "$tmp" "$TOKENS_FILE"
  chmod 600 "$TOKENS_FILE"
}

# remove_token <repo> — deletes the stored PAT for <repo>, if any. Mirrors
# save_token's grep-filter-then-rewrite pattern but drops the line instead of
# replacing it. No-op (not an error) when TOKENS_FILE is missing or the key
# isn't present. Used by `vibe repos remove --purge` (task_017) to offer
# dropping a shared repo's token alongside the registry entry.
remove_token() {
  local repo="$1"
  [ -f "$TOKENS_FILE" ] || return 0
  local tmp
  tmp=$(mktemp)
  awk -v k="${repo}" 'index($0, k"=")!=1' "$TOKENS_FILE" > "$tmp" || true
  mv "$tmp" "$TOKENS_FILE"
  chmod 600 "$TOKENS_FILE"
}

setup_token() {
  local repo="$1"
  local repo_short="${repo#*/}"
  local token_name="vibe-$repo_short"
  local clip_note

  # Best-effort: pre-load the Mac clipboard with the suggested token name so
  # the user can ⌘V into GitHub's 'Token name' field without retyping. Silent
  # fallback if pbcopy is unavailable (e.g. Linux host) — message degrades
  # gracefully to the original "e.g.: vibe-<repo>" wording.
  if command -v pbcopy >/dev/null 2>&1 && printf '%s' "$token_name" | pbcopy 2>/dev/null; then
    clip_note=" (clipboard has '$token_name' — ⌘V into 'Token name')"
  else
    clip_note=", e.g.: $token_name"
  fi

  cat << MSG

  No GitHub token found for $repo.

  I'll open GitHub so you can create a fine-grained token.
  On that page:
    1. Give it a name${clip_note}
    2. Set an expiry (90 days is a good default)
    3. Under 'Repository access' → 'Only select repositories'
       → choose $repo_short
    4. Under 'Permissions' enable:
         Contents        → Read and write
         Metadata        → Read-only  (auto-selected)
         Pull requests   → Read and write
    5. Click 'Generate token' and copy it

MSG
  read -rp "  Press Enter to open GitHub in your browser (or Ctrl+C to skip)..."
  open "https://github.com/settings/personal-access-tokens/new"
  echo ""
  read -rsp "  Paste your token (input is hidden): " input_token
  echo ""

  if [ -z "$input_token" ]; then
    echo "  No token entered — launching without GitHub auth."
    GITHUB_TOKEN=""
    return
  fi

  save_token "$repo" "$input_token"
  echo "  ✓ Token saved — you won't be asked again for this repo."
  GITHUB_TOKEN="$input_token"
}

# ── Docker config helpers ─────────────────────────────────────────────────────

# Disable Docker CLI's "What's next?" hints by setting features.hints="false"
# in ~/.docker/config.json. Idempotent. Respects an explicit user string
# choice, but coerces bool values (written by earlier vibe versions or older
# Docker releases) — current Docker CLI rejects non-string feature values
# and prints a WARNING on every invocation until fixed. Bails on malformed
# JSON rather than trampling the user's config.
ensure_docker_hints_off() {
  local cfg="$HOME/.docker/config.json"
  mkdir -p "$(dirname "$cfg")"
  if [ ! -f "$cfg" ] || [ ! -s "$cfg" ]; then
    printf '{\n  "features": {\n    "hints": "false"\n  }\n}\n' > "$cfg"
    return
  fi
  python3 - "$cfg" << 'PY'
import json, sys
path = sys.argv[1]
try:
    with open(path) as f:
        original = f.read()
    cfg = json.loads(original)
except (json.JSONDecodeError, OSError, ValueError):
    sys.exit(0)

features = cfg.get("features")
if not isinstance(features, dict):
    features = {}
    cfg["features"] = features

for k, v in list(features.items()):
    if isinstance(v, bool):
        features[k] = "true" if v else "false"

if not isinstance(features.get("hints"), str):
    features["hints"] = "false"

new = json.dumps(cfg, indent=2) + "\n"
if new != original:
    with open(path, "w") as f:
        f.write(new)
PY
}

# ── Claude-invocation builder ─────────────────────────────────────────────────
# Echoes the resume-related arg fragment to prepend to claude's argv based on
# CONTINUE / RESUME / RESUME_UID. Empty string for fresh launch. Defined here
# (above the VIBE_SOURCE_ONLY guard) so smoke-test.py can exercise it.
build_claude_resume_args() {
  if [ "${CONTINUE:-false}" = "true" ]; then
    echo "--continue"
  elif [ "${RESUME:-false}" = "true" ]; then
    if [ -n "${RESUME_UID:-}" ]; then
      echo "--resume $RESUME_UID"
    else
      echo "--resume"
    fi
  fi
}

# Returns 0 if the argument is a UUID (8-4-4-4-12 hex), 1 otherwise. Used by
# the flag parser to decide whether the token after --resume is a session id
# (consume it) or the next flag / project name (leave it for later parsing).
is_uuid() {
  [[ "${1:-}" =~ ^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$ ]]
}

# ── Model selection (--fable / --model / VIBE_MODEL) ──────────────────────────
# All defined above the VIBE_SOURCE_ONLY guard so smoke-test.py can unit-test
# them. MODEL_ARG is set by parse_vibe_args (flags) or from VIBE_MODEL (config).

FABLE_MODEL_ID="claude-fable-5"
# Fable 5 is included in Pro/Max subscriptions 9 Jun – 7 Jul 2026; from 8 Jul it
# bills usage credits at API list rates instead (per Anthropic's launch notice).
FABLE_CREDITS_FROM="20260708"

# Model ids are embedded into the bash -c command string passed to the
# container, so restrict them to a safe charset (letters, digits, dot, dash,
# underscore), starting alphanumeric. Rejects empty, anything
# shell-significant, and leading-dash tokens (so `--model --continue` errors
# instead of eating the next flag).
is_model_id() {
  [[ "${1:-}" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]]
}

# build_claude_model_args echoes "--model <id>" when MODEL_ARG is set, else "".
# MODEL_ARG is charset-restricted by is_model_id in the parser, so embedding it
# in the command string is injection-safe (same pattern as RESUME_UID).
build_claude_model_args() {
  if [ -n "${MODEL_ARG:-}" ]; then
    echo "--model $MODEL_ARG"
  fi
}

# fable_billing_phase [yyyymmdd] — echoes "free" before the credits cutover
# date, "credits" from it onward. Date injectable for tests; defaults to the
# host's local date (day-level precision is enough for a billing notice).
# shellcheck disable=SC2120  # the optional date arg is passed only by tests
fable_billing_phase() {
  local today="${1:-$(date +%Y%m%d)}"
  if [ "$today" -lt "$FABLE_CREDITS_FROM" ]; then
    echo "free"
  else
    echo "credits"
  fi
}

# ── Auto-resume helpers (marker-driven relaunch after credit exhaustion) ──────
# /vsss --sessions X writes .vss/auto-resume in the project as KEY=VALUE
# lines: active (1/0), remaining (relaunches left), resume_at (epoch estimate
# of the 5h-window reset), session_file. When claude exits while the marker is
# active with relaunches remaining, the launcher waits until resume_at and
# relaunches `claude --continue "/vsss --resume"`. The skill sets active=0 at
# any clean Final-state exit, so finished loops never relaunch. Manual
# override: delete .vss/auto-resume, or Ctrl-C during the countdown.
#
# Stall watchdog (heartbeat-driven kill of a wedged usage-limit picker):
# interactive claude does NOT exit when a Pro/Max usage window runs out — it
# blocks forever at an interactive picker, so the relaunch loop above never
# runs on its own. settings.local.json's PreToolUse/PostToolUse/Stop hooks
# (see the heredoc below) write an epoch to .vss/heartbeat while the marker
# exists; launch_claude_supervised backgrounds claude, captures its PID, and
# runs vibe_stall_watchdog alongside it. The watchdog's kill gate is THREE
# conditions, ALL required, so a crash-left marker in an unrelated later
# interactive session is never mistaken for a live --sessions run: (1) marker
# active=1 (auto_resume_field, not auto_resume_pending, so the FINAL window —
# remaining=0 — is still protected from an unwanted kill); (2) the marker was
# refreshed DURING THIS launcher session — proven portably via
# `[ marker -nt ref ]` against a session-start reference file (VIBE_SESSION_REF)
# — OR the call site is a relaunch, which arms unconditionally via the literal
# sentinel "-" (a freshly relaunched window may be stalled at the picker
# before the skill gets a chance to refresh anything); an EMPTY ref (e.g.
# mktemp failure) NEVER arms — fail-safe toward not killing; (3) the
# heartbeat is provably stale (auto_resume_stalled, default 1800s — 30 min of
# no hook events, including subagent tool calls, reliably means the picker,
# not a legitimately long-running command). On trigger: warn, wait a grace
# period, re-check all three, then kill in-container first
# (vibe_container_kill_claude), pause for that to land, and fall back to the
# host client PID. With relaunches remaining this drops straight into the
# existing countdown/relaunch loop below; on the final window (remaining=0)
# the loop is simply not entered and the launcher exits cleanly instead of
# hanging forever. The watchdog's own lifetime is bounded by claude-PID
# liveness alone (kill -0 in its poll loop) — no EXIT-trap dependency, so the
# clipboard-watcher flush (registered via the vibe_on_exit dispatcher, behaviour
# unchanged) is unaffected; an orphaned watchdog
# (launcher died mid-wait) notices claude's death within one poll interval.
# Ctrl-C during the countdown deactivates the marker (auto_resume_deactivate)
# via a per-iteration INT trap — cancel means cancel, but crash-left markers
# must still resume, so nothing else touches the marker on any other exit
# path. Claude's exit status is captured past the old `set -e`-guarding
# `|| true` swallow and propagated as vibe's own final exit code
# ($CLAUDE_EXIT).

# auto_resume_field <file> <key> — echoes the last value for key, digits only
# (missing file, missing key, or non-numeric value → echoes nothing). Keeping
# the charset numeric makes the arithmetic and relaunch logic injection-proof.
auto_resume_field() {
  local file="$1" key="$2" val
  [ -f "$file" ] || return 0
  val=$(grep -E "^${key}=" "$file" 2>/dev/null | tail -1 | cut -d= -f2)
  case "$val" in
    ''|*[!0-9]*) ;;
    *) echo "$val" ;;
  esac
}

# auto_resume_pending <file> — true when the marker asks for a relaunch:
# active=1 and remaining >= 1. Fails safe: any malformed field means no loop.
auto_resume_pending() {
  local file="$1" active remaining
  active=$(auto_resume_field "$file" active)
  remaining=$(auto_resume_field "$file" remaining)
  [ "$active" = "1" ] && [ -n "$remaining" ] && [ "$remaining" -ge 1 ]
}

# auto_resume_decrement <file> — rewrite the marker with remaining reduced by
# one. awk-to-temp instead of sed -i (BSD/GNU sed -i syntax differs).
auto_resume_decrement() {
  local file="$1" tmp
  tmp="${file}.tmp.$$"
  awk -F= 'BEGIN{OFS="="} $1=="remaining" && $2 ~ /^[0-9]+$/ {$2=$2-1} {print}' \
    "$file" > "$tmp" && mv "$tmp" "$file"
}

# auto_resume_deactivate <file> — rewrite the marker with active=0, preserving
# every other line. Same awk-to-temp+mv pattern as auto_resume_decrement.
# Idempotent (running it twice leaves active=0). Missing file → return 0
# WITHOUT creating one (cancelling a run that never wrote a marker is a
# no-op, not an error).
auto_resume_deactivate() {
  local file="$1" tmp
  [ -f "$file" ] || return 0
  tmp="${file}.tmp.$$"
  awk -F= 'BEGIN{OFS="="} $1=="active" {$2="0"} {print}' \
    "$file" > "$tmp" && mv "$tmp" "$file"
}

# auto_resume_heartbeat_write <file> — atomically writes the current epoch
# (date +%s) as the file's only content; same temp+mv pattern. Guarded so it
# can NEVER return non-zero or trip `set -e` — an unwritable .vss dir (or any
# other failure) is a silent no-op, and the temp file is cleaned up rather
# than left behind if the write or rename fails partway.
auto_resume_heartbeat_write() {
  local file="$1" tmp
  tmp="${file}.tmp.$$"
  if ! { date +%s > "$tmp" 2>/dev/null && mv "$tmp" "$file" 2>/dev/null; }; then
    rm -f "$tmp" 2>/dev/null || true
  fi
  return 0
}

# auto_resume_stalled <hb_file> <now_epoch> <stall_secs> — 0 (stalled) iff
# the file's first line is a digits-only epoch AND now-epoch > stall_secs
# (strict). Fail-safe returns 1 (not stalled) for a missing/empty file,
# non-numeric content, a future epoch, and the exact boundary (gap ==
# stall_secs) — a malformed or absent heartbeat must never look stale enough
# to justify a kill.
auto_resume_stalled() {
  local file="$1" now="$2" thresh="$3" epoch gap
  [ -f "$file" ] || return 1
  epoch=$(head -1 "$file" 2>/dev/null)
  case "$epoch" in
    ''|*[!0-9]*) return 1 ;;
  esac
  gap=$(( now - epoch ))
  [ "$gap" -gt "$thresh" ]
}

# vibe_container_kill_claude — best-effort SIGTERM to the claude process
# inside the project's container. A named function (not inlined) so
# smoke-test can stub it after sourcing, mirroring the existing docker()
# stub precedent. Every failure mode is swallowed (`|| true`) — the
# container may already be gone, or claude may have already exited. MUST
# stay a literal, bare, non-`exec`-prefixed `devcontainer exec` invocation:
# this is the surviving bare `devcontainer exec` line that keeps
# test_vibe_final_line_no_exec's assertion (b) passing now that
# launch_claude's body below is `exec devcontainer exec ...` (assertion a).
vibe_container_kill_claude() {
  devcontainer exec --workspace-folder "$WORKSPACE" --override-config "$OVERRIDE_CONFIG" pkill -TERM -x claude || true
}

# _vibe_stall_armed <marker_file> <ref_file> — kill-gate conditions 1+2 (see
# vibe_stall_watchdog): marker active=1 AND either the literal relaunch
# sentinel "-" (unconditional arm) or a non-empty, existing session-start ref
# file that the marker is newer than (portable POSIX `-nt`, no stat -c/-f).
# An empty or missing ref never arms (mktemp-failure fail-safe). Split out
# from auto_resume_stalled (condition 3) so the watchdog can re-check the
# cheap conditions first without a fresh heartbeat read every retry.
_vibe_stall_armed() {
  local marker="$1" ref="$2"
  [ "$(auto_resume_field "$marker" active)" = "1" ] || return 1
  [ "$ref" = "-" ] && return 0
  [ -n "$ref" ] && [ -f "$ref" ] && [ "$marker" -nt "$ref" ]
}

# vibe_stall_watchdog <claude_pid> <marker_file> <hb_file> <ref_file> —
# backgrounded by launch_claude_supervised alongside claude. Polls every
# ${VIBE_STALL_POLL_SECS:-60}s while claude is alive (kill -0). On the first
# poll where all three kill-gate conditions hold (_vibe_stall_armed plus a
# stale heartbeat via auto_resume_stalled, default threshold 1800s): prints a
# loud stderr warning (bell + threshold + cancel instruction), sleeps
# ${VIBE_STALL_GRACE_SECS:-120}, re-checks all three conditions, and only if
# STILL met kills in-container first (vibe_container_kill_claude), pauses
# ${VIBE_STALL_KILL_PAUSE_SECS:-10} for that to land, then falls back to the
# host client PID (`kill "$claude_pid"`) — never a host-side pkill. Either
# way the function returns after handling this one escalation. All sleeps
# are individually guarded so a signal or interrupted syscall can't trip
# `set -e`; lifetime is bounded solely by claude-PID liveness, so an orphaned
# watchdog (launcher died mid-wait) exits on its own within one poll interval.
vibe_stall_watchdog() {
  local claude_pid="$1" marker="$2" hb="$3" ref="$4"
  local poll="${VIBE_STALL_POLL_SECS:-60}"
  local grace="${VIBE_STALL_GRACE_SECS:-120}"
  local stall_secs="${VIBE_STALL_SECS:-1800}"
  local kill_pause="${VIBE_STALL_KILL_PAUSE_SECS:-10}"

  while kill -0 "$claude_pid" 2>/dev/null; do
    sleep "$poll" 2>/dev/null || true
    if _vibe_stall_armed "$marker" "$ref" \
       && auto_resume_stalled "$hb" "$(date +%s)" "$stall_secs"; then
      printf '\n  \a⚠  auto-resume: no activity for over %ss — assuming the usage-limit picker is stuck.\n' "$stall_secs" >&2
      printf '     Waiting %ss then killing this claude window (delete .vss/auto-resume to cancel).\n' "$grace" >&2
      sleep "$grace" 2>/dev/null || true
      if _vibe_stall_armed "$marker" "$ref" \
         && auto_resume_stalled "$hb" "$(date +%s)" "$stall_secs"; then
        vibe_container_kill_claude
        sleep "$kill_pause" 2>/dev/null || true
        kill "$claude_pid" 2>/dev/null || true
      fi
      return 0
    fi
  done
  return 0
}

# ── Exit-hook dispatcher (the ONLY `trap ... EXIT` in this script) ────────────
# bash keeps ONE command per trap slot, so a second `trap ... EXIT` silently
# REPLACES the first — which is exactly how a shared-repo lock-release trap
# would have eaten the Darwin clipboard-flush trap (or vice versa). All EXIT
# work therefore goes through a single dispatcher: vibe_exit_hook_add appends
# a command string to VIBE_EXIT_HOOKS and installs `trap vibe_on_exit EXIT`
# exactly once, on first use. The dispatcher runs hooks in registration
# order, EACH individually guarded with `|| true` — this script runs under
# `set -euo pipefail`, and one refusing hook (shared_repo_lock_release in the
# routine never-held-the-lock case, say) would otherwise abort the trap
# handler and silently skip every later-registered hook — the exact
# clipboard-flush regression task_016 refused to risk. Register through
# vibe_exit_hook_add ONLY; never `trap ... EXIT` directly. Crash paths
# (SIGKILL, power loss) run no EXIT hooks by definition — anything that must
# survive them is designed around it (the rw lock's stale-reclaim handles a
# dead holder pid; crash-left auto-resume markers deliberately persist).
VIBE_EXIT_HOOKS=()
VIBE_EXIT_TRAP_INSTALLED=""

# vibe_on_exit — run every registered hook, in order, each guarded. The
# empty-array early return also dodges bash 3.2's set -u objection to
# expanding an empty array (macOS ships 3.2; same discipline as the
# mount_args count checks elsewhere).
vibe_on_exit() {
  local _vibe_hook
  [ "${#VIBE_EXIT_HOOKS[@]}" -eq 0 ] && return 0
  for _vibe_hook in "${VIBE_EXIT_HOOKS[@]}"; do
    eval "$_vibe_hook" || true
  done
  return 0
}

# vibe_exit_hook_add <command-string> — append a hook and install the single
# EXIT trap on first use. This function is the dispatcher INSTALLER — the one
# place `trap ... EXIT` is allowed.
vibe_exit_hook_add() {
  VIBE_EXIT_HOOKS+=("$1")
  if [ -z "$VIBE_EXIT_TRAP_INSTALLED" ]; then
    trap vibe_on_exit EXIT
    VIBE_EXIT_TRAP_INSTALLED=1
  fi
}

# ── Shared-repo single-writer rw lock (task_017 slice 2) ──────────────────────
# One writer per shared checkout per Mac, refereed by a lock DIRECTORY at
# <checkout>/.vibe-signals/rw-lock.d/ — a directory because `mkdir` is the
# atomic acquire (no test-then-write race, works on every local filesystem;
# cross-machine coordination is explicitly out of scope). Metadata lives in
# rw-lock.d/meta as KEY=VALUE lines: project=<name>, pid=<launcher pid>,
# since=<epoch>; pid/since are digits-only on read (auto_resume_field's
# injection discipline). Stale-reclaim: a holder whose pid no longer exists
# (kill -0 fails) is dead — remove the lock dir and retry the mkdir exactly
# ONCE. A missing or malformed meta is treated as HELD-by-unknown, never as
# stale: acquire is mkdir-then-write, so a contender can observe the dir
# before meta lands, and stealing that window would break single-writer.
# Contention resolves toward ro (fail-safe: never grant a write mount on a
# doubtful lock); a killed launcher leaves the lock and the NEXT acquirer's
# stale-reclaim collects it — no other cleanup mechanism exists or is needed.
#
# INTEGRATION STUBS (C1 symbols this cycle codes against, all guarded):
#   shared_repos_parse <file>        — echoes validated "slug mode" lines
#   repos_registry_lookup <slug>     — echoes the local checkout path or nothing
#   shared_repo_ensure_signals <dir> — sidecar mkdir -p + gitignore, idempotent
# Absent any of them (cycles landing out of order), the rw-intent pass below
# no-ops rather than inventing C1 machinery. C1 also owns the `vibe repos`
# dispatch block (the literal `if [ "${1:-}" = "repos" ]` before
# parse_vibe_args); `vibe repos add --rw <slug>` wires there into
#   shared_repo_declaration_set_mode "$WORKSPACE/.vibe-repos" "$slug" rw
# — the helper ships fully implemented below, C1 owns the one dispatch line.

# _shared_repo_lock_dir <checkout> — the lock path shape, defined once.
_shared_repo_lock_dir() {
  echo "$1/.vibe-signals/rw-lock.d"
}

# _shared_repo_meta_field <meta_file> <key> [digits] — echoes the last value
# for key (everything after the first =); with "digits", non-numeric values
# echo nothing. Missing file/key echoes nothing. Fail-safe like
# auto_resume_field, which it mirrors.
_shared_repo_meta_field() {
  local file="$1" key="$2" want="${3:-}" val
  [ -f "$file" ] || return 0
  val=$(grep -E "^${key}=" "$file" 2>/dev/null | tail -1 | cut -d= -f2-)
  if [ "$want" = "digits" ]; then
    case "$val" in
      ''|*[!0-9]*) return 0 ;;
    esac
  fi
  [ -n "$val" ] && printf '%s\n' "$val"
  return 0
}

# shared_repo_lock_holder <checkout> — echoes "project pid since" for the
# current holder (pid/since digits-only, blank when malformed; project may
# legitimately contain spaces, so callers must parse the LAST two fields as
# pid/since and treat the remainder as the name). Echoes nothing when no
# lock/meta exists.
shared_repo_lock_holder() {
  local meta project pid since
  meta="$(_shared_repo_lock_dir "$1")/meta"
  [ -f "$meta" ] || return 0
  project=$(_shared_repo_meta_field "$meta" project)
  pid=$(_shared_repo_meta_field "$meta" pid digits)
  since=$(_shared_repo_meta_field "$meta" since digits)
  echo "$project $pid $since"
}

# _shared_repo_lock_write_meta <meta_path> <project> <pid> — write the meta
# file; plain > is fine (the surrounding lock DIR is the atomicity boundary —
# nobody else can be inside a dir they failed to mkdir).
_shared_repo_lock_write_meta() {
  printf 'project=%s\npid=%s\nsince=%s\n' "$2" "$3" "$(date +%s)" > "$1" 2>/dev/null
}

# shared_repo_lock_acquire <checkout> <project> <pid> — returns 0 acquired,
# 1 held-by-someone-else (holder details echoed as "project pid since").
# RE-ENTRANT on (project, pid): a meta matching both is already ours →
# return 0 without touching anything. That re-entrancy is load-bearing:
# _build_override_config runs inside $(...), where lock side effects would
# be invisible to the launcher, so the MAIN shell takes the lock first
# (shared_repos_apply_rw_intents) and mount assembly merely re-reads the
# answer — $$ inside a command-substitution subshell is the parent's pid, so
# both calls present identical credentials. On meta-write failure the fresh
# lock dir is rolled back and the acquire reports held (a dir with no meta
# is unreleasable by us and unreclaimable by others — worse than losing).
shared_repo_lock_acquire() {
  local checkout="$1" project="$2" pid="$3" lock meta hpid
  lock="$(_shared_repo_lock_dir "$checkout")"
  meta="$lock/meta"
  # Re-entrant fast path: we already hold it.
  if [ -f "$meta" ] \
     && [ "$(_shared_repo_meta_field "$meta" project)" = "$project" ] \
     && [ "$(_shared_repo_meta_field "$meta" pid digits)" = "$pid" ]; then
    return 0
  fi
  # Defensive sidecar mkdir (spec: never rely on Docker auto-vivification;
  # also lets the lock helpers be exercised standalone against a bare temp
  # checkout). shared_repo_ensure_signals (C1) remains the full-fat path —
  # this covers only the parent-dir-for-mkdir need, guarded.
  mkdir -p "${lock%/*}" 2>/dev/null || true
  if mkdir "$lock" 2>/dev/null; then
    if _shared_repo_lock_write_meta "$meta" "$project" "$pid"; then
      return 0
    fi
    rm -rf "$lock" 2>/dev/null || true
    return 1
  fi
  # Held. Stale ONLY when the holder pid parses digits-only AND is dead;
  # reclaim exactly once, then one retry of the atomic mkdir.
  hpid=$(_shared_repo_meta_field "$meta" pid digits)
  if [ -n "$hpid" ] && ! kill -0 "$hpid" 2>/dev/null; then
    rm -rf "$lock" 2>/dev/null || true
    if mkdir "$lock" 2>/dev/null; then
      if _shared_repo_lock_write_meta "$meta" "$project" "$pid"; then
        return 0
      fi
      rm -rf "$lock" 2>/dev/null || true
      return 1
    fi
  fi
  shared_repo_lock_holder "$checkout"
  return 1
}

# shared_repo_lock_release <checkout> <project> <pid> — remove the lock ONLY
# when meta matches BOTH project and pid: never someone else's lock, never a
# half-written one (missing/malformed meta refuses too). Returns 0 released,
# 1 refused-or-nothing-held. The routine never-held case returning 1 is WHY
# the exit dispatcher guards every hook with `|| true` — release is always
# registered via vibe_exit_hook_add, never as a raw trap.
shared_repo_lock_release() {
  local checkout="$1" project="$2" pid="$3" lock meta
  lock="$(_shared_repo_lock_dir "$checkout")"
  meta="$lock/meta"
  [ -d "$lock" ] || return 1
  [ "$(_shared_repo_meta_field "$meta" project)" = "$project" ] || return 1
  [ "$(_shared_repo_meta_field "$meta" pid digits)" = "$pid" ] || return 1
  rm -rf "$lock" 2>/dev/null || return 1
  return 0
}

# shared_repo_resolve_mode <slug> <checkout> <declared-mode> — echoes the
# EFFECTIVE mount mode for a shared repo. "ro" (or anything that isn't the
# exact token "rw" — unknown modes degrade toward not granting writes)
# passes through untouched, no lock traffic. "rw" intent is refereed by the
# single-writer lock: acquired (or already ours — re-entrant) → "rw"; held
# elsewhere → "ro" fallback (the caller prints the loud holder warning;
# shared_repo_lock_holder has the details). This is THE one call-site
# function for C1's mount-assembly loop:
#   mode=$(shared_repo_resolve_mode "$slug" "$checkout" "$declared_mode")
# The lock was already taken (or refused) by shared_repos_apply_rw_intents
# in the main shell before mount assembly ran, so this re-read cannot
# double-acquire or flip the answer mid-launch. Always returns 0.
# shellcheck disable=SC2034  # slug is part of the pinned signature; the
# lock is per-checkout, but call sites pass the slug for future-proofing.
shared_repo_resolve_mode() {
  local slug="$1" checkout="$2" declared="${3:-ro}" project
  if [ "$declared" != "rw" ]; then
    echo "ro"
    return 0
  fi
  project="${PROJECT_NAME:-$(basename "${WORKSPACE:-$PWD}")}"
  if shared_repo_lock_acquire "$checkout" "$project" "$$" >/dev/null; then
    echo "rw"
  else
    echo "ro"
  fi
  return 0
}

# shared_repo_declaration_set_mode <file> <slug> <mode> — set/update the mode
# field on <slug>'s line in a .vibe-repos declaration (creates the file or
# appends the line when absent). awk-to-temp + mv, the same portable rewrite
# pattern as auto_resume_decrement; comments, blank lines and other entries
# pass through byte-unchanged. Validates here too (slug charset, ro|rw mode,
# reserved dot-prefixed basenames) — this is the write path `vibe repos add
# --rw` wires into, and it must refuse garbage even if the caller forgot to.
shared_repo_declaration_set_mode() {
  local file="$1" slug="$2" mode="$3" tmp
  [[ "$slug" =~ ^[A-Za-z0-9._-]+/[A-Za-z0-9._-]+$ ]] || return 1
  case "${slug##*/}" in .*) return 1 ;; esac
  case "$mode" in ro|rw) ;; *) return 1 ;; esac
  if [ ! -f "$file" ]; then
    printf '%s %s\n' "$slug" "$mode" > "$file"
    return 0
  fi
  tmp="${file}.tmp.$$"
  awk -v slug="$slug" -v mode="$mode" '
    $0 !~ /^[[:space:]]*(#|$)/ && $1 == slug { print slug " " mode; found=1; next }
    { print }
    END { if (!found) print slug " " mode }
  ' "$file" > "$tmp" && mv "$tmp" "$file"
}

# VIBE_RW_LOCKED_CHECKOUTS / VIBE_SHARED_REPO_WARNINGS — filled by
# shared_repos_apply_rw_intents in the MAIN shell: locked checkouts get a
# release hook each; warnings are printed later inside the launch header
# (collected rather than echoed inline so they land in the banner block,
# not above it).
VIBE_RW_LOCKED_CHECKOUTS=()
VIBE_SHARED_REPO_WARNINGS=()

# shared_repos_apply_rw_intents <declaration_file> <project> <pid> — the
# main-shell rw-intent pass, run ONCE per launch BEFORE mount assembly.
# It must run in the launcher's own shell: lock acquisition is a side effect
# and the release hooks register into VIBE_EXIT_HOOKS — both die inside the
# $(...) that invokes _build_override_config (the same subshell trap the
# learning_load comment at the OVERRIDE_CONFIG call site documents). For
# each declared rw repo that resolves via the machine registry to an
# existing checkout: attempt the lock; on success register the release as an
# exit hook (release only ever matches OUR project+pid); on contention queue
# a loud header warning naming the holder project + since-time and leave the
# mode ro. Repos with no registry entry are silently skipped, mirroring
# mount assembly's community-contributor silence. Guarded against C1's
# helpers being absent (cycles can land out of order): no parser/registry →
# no-op. Always returns 0 (launch must never abort over lock traffic).
shared_repos_apply_rw_intents() {
  local decl="$1" project="$2" pid="$3"
  local line slug declared checkout holder rest hproject hsince since_fmt
  [ -f "$decl" ] || return 0
  type shared_repos_parse >/dev/null 2>&1 || return 0
  type repos_registry_lookup >/dev/null 2>&1 || return 0
  while IFS= read -r line; do
    [ -n "$line" ] || continue
    slug="${line%% *}"
    declared="${line#* }"
    [ "$declared" = "rw" ] || continue
    checkout="$(repos_registry_lookup "$slug")" || checkout=""
    { [ -n "$checkout" ] && [ -d "$checkout" ]; } || continue
    if shared_repo_lock_acquire "$checkout" "$project" "$pid" >/dev/null; then
      VIBE_RW_LOCKED_CHECKOUTS+=("$checkout")
      # printf %q so a checkout path (or project name) with spaces/quotes
      # survives the dispatcher's eval verbatim.
      vibe_exit_hook_add "shared_repo_lock_release $(printf '%q' "$checkout") $(printf '%q' "$project") $pid"
    else
      holder="$(shared_repo_lock_holder "$checkout")"
      # Parse from the RIGHT: pid/since are the last two fields; the
      # remainder is the project name (which may contain spaces).
      hsince="${holder##* }"
      rest="${holder% *}"
      hproject="${rest% *}"
      case "$hsince" in
        ''|*[!0-9]*) since_fmt="unknown" ;;
        *) since_fmt="$(date -r "$hsince" 2>/dev/null || date -d "@$hsince" 2>/dev/null || echo "epoch $hsince")" ;;
      esac
      [ -n "$hproject" ] || hproject="unknown"
      VIBE_SHARED_REPO_WARNINGS+=("     ⚠ shared repo ${slug}: rw declared but the lock is held by '${hproject}' (since ${since_fmt}) — mounting ro this session")
    fi
  done <<EOF
$(shared_repos_parse "$decl")
EOF
  return 0
}

# ── Learning library helpers ──────────────────────────────────────────────────
# All helpers are defined here, BEFORE the VIBE_SOURCE_ONLY guard, so that
# smoke-test.py can unit-test them via VIBE_SOURCE_ONLY=1.

# learning_config_path — echoes the path to the learning config file.
learning_config_path() {
  echo "$HOME/.vibe/learning.config"
}

# learning_load — strict-parses learning.config; exports the four recognised
# vars. Never uses source or eval. Returns 0 always (silent on missing config).
learning_load() {
  # Unset/clear the four vars first so a missing key isn't inherited from env.
  VIBE_LEARNING_ENABLED=""
  VIBE_LEARNING_PATH=""
  VIBE_LEARNING_VISIBILITY=""
  VIBE_LEARNING_GIT_REMOTE=""

  local cfg
  cfg=$(learning_config_path)
  [ -f "$cfg" ] || return 0

  # Use python3 for the strict parse: accepted keys + regex ^[A-Z_]+="[^"\\$`]*"$
  # Never source or eval — python opens the file and emits only safe KEY=VALUE lines.
  local parsed
  parsed=$(python3 - "$cfg" << 'PY'
import re, sys
path = sys.argv[1]
ALLOWED = {"VIBE_LEARNING_ENABLED", "VIBE_LEARNING_PATH",
           "VIBE_LEARNING_VISIBILITY", "VIBE_LEARNING_GIT_REMOTE"}
pattern = re.compile(r'^([A-Z_]+)="([^"\\$`]*)"$')
try:
    with open(path) as f:
        for line in f:
            line = line.rstrip('\n')
            m = pattern.match(line)
            if m and m.group(1) in ALLOWED:
                # Output as KEY=VALUE with value shell-quoted via repr-like escaping.
                # Values are already guaranteed to contain no shell-special chars
                # (no quotes, backslashes, dollar signs, backticks) by the regex.
                print(m.group(1) + '=' + m.group(2))
except OSError:
    pass
PY
  ) || return 0

  # Consume the parsed KEY=VALUE lines (values have no shell metacharacters).
  local line key value
  while IFS= read -r line; do
    key="${line%%=*}"
    value="${line#*=}"
    case "$key" in
      VIBE_LEARNING_ENABLED)    VIBE_LEARNING_ENABLED="$value" ;;
      VIBE_LEARNING_PATH)       VIBE_LEARNING_PATH="$value" ;;
      VIBE_LEARNING_VISIBILITY) VIBE_LEARNING_VISIBILITY="$value" ;;
      VIBE_LEARNING_GIT_REMOTE) VIBE_LEARNING_GIT_REMOTE="$value" ;;
    esac
  done <<< "$parsed"

  export VIBE_LEARNING_ENABLED VIBE_LEARNING_PATH \
         VIBE_LEARNING_VISIBILITY VIBE_LEARNING_GIT_REMOTE
  return 0
}

# learning_is_enabled — exits 0 iff config has ENABLED=true, non-empty PATH
# pointing at an existing directory. Silent.
learning_is_enabled() {
  [ "${VIBE_LEARNING_ENABLED:-}" = "true" ] || return 1
  [ -n "${VIBE_LEARNING_PATH:-}" ] || return 1
  [ -d "${VIBE_LEARNING_PATH:-}" ] || return 1
  return 0
}

# learning_project_opted_out <walk_start_abs_path> — walks from the given
# absolute path upward toward /, stopping at $HOME (inclusive) or the first
# dir containing .no-learn (or legacy .vibe-no-learn). Exits 0 if opted out
# (marker found, or $HOME unset/empty as fail-safe). Exits 1 if not opted
# out. Silent.
learning_project_opted_out() {
  local start="${1:-}"

  # Fail-safe: if $HOME is unset or empty, treat as opted-out.
  if [ -z "${HOME:-}" ]; then
    return 0
  fi

  # If start path is empty, treat as opted-out.
  if [ -z "$start" ]; then
    return 0
  fi

  local dir="$start"
  while true; do
    # Check for marker at this level. Accept new short name and legacy.
    if [ -e "$dir/.no-learn" ] || [ -e "$dir/.vibe-no-learn" ]; then
      return 0
    fi
    # Stop after checking $HOME itself — do not walk above it.
    if [ "$dir" = "$HOME" ]; then
      return 1
    fi
    # Walk up.
    local parent
    parent="$(dirname "$dir")"
    # Stop if we've hit filesystem root (dirname of / is /).
    if [ "$parent" = "$dir" ]; then
      return 1
    fi
    dir="$parent"
  done
}

# learning_should_mount <workspace_abs_path> — exits 0 iff learning is enabled
# AND the project is not opted out. Silent.
learning_should_mount() {
  local workspace="${1:-}"
  learning_is_enabled || return 1
  learning_project_opted_out "$workspace" && return 1
  return 0
}

# learning_banner_state <workspace_abs_path> — echoes one of:
#   silent    → learning not enabled globally (nothing to say)
#   excluded  → enabled globally, this project has a .no-learn marker
#   enabled   → enabled globally, this project is opted in
# Silence is reserved for the never-configured case so users can tell
# "I just excluded this project" from "I never opted in".
learning_banner_state() {
  local workspace="${1:-}"
  if ! learning_is_enabled; then
    echo "silent"
    return 0
  fi
  if learning_project_opted_out "$workspace"; then
    echo "excluded"
    return 0
  fi
  echo "enabled"
  return 0
}

# learning_entry_path <library_abs_path> <iso8601> <rand6_hex> — pure string
# composition; echoes the full file path. No filesystem access.
learning_entry_path() {
  local lib="$1" ts="$2" rand="$3"
  echo "${lib}/${ts}-${rand}.md"
}

# learning_format_entry <iso8601> <pattern> — pure: echoes the markdown entry
# body. No I/O side effects.
learning_format_entry() {
  local ts="$1" pattern="$2"
  printf '# %s\n\n%s\n' "$ts" "$pattern"
}

# learning_commit_message <pattern> — pure: echoes a git commit message
# (first 60 chars of pattern, newlines → spaces, whitespace collapsed).
# Delivered via --file=<tempfile> so no shell-metachar escaping is needed.
learning_commit_message() {
  local pattern="$1"
  # Replace newlines with spaces, collapse runs of whitespace, truncate to 60 chars.
  local collapsed
  collapsed=$(printf '%s' "$pattern" | tr '\n' ' ' | tr -s ' ')
  printf 'learn: %s\n' "${collapsed:0:60}"
}

# render_devcontainer_with_mounts <src_json> <dst_json> [<source> <target> <ro>]...
# Reads src JSON, appends one bind-mount entry per (source, target, ro) triple
# to the mounts array (creating it if absent), writes dst. ro is "1" for
# readonly, anything else for read-write. Paths are passed as argv (not
# interpolated into JSON text) so sources with spaces/quotes are safe.
render_devcontainer_with_mounts() {
  local src="$1" dst="$2"
  shift 2
  python3 - "$src" "$dst" "$@" << 'PY'
import json, os, sys
src, dst = sys.argv[1], sys.argv[2]
rest = sys.argv[3:]
with open(src) as f:
    cfg = json.load(f)
if not isinstance(cfg.get("mounts"), list):
    cfg["mounts"] = []
for i in range(0, len(rest), 3):
    source, target, ro = rest[i], rest[i + 1], rest[i + 2]
    entry = {"source": source, "target": target, "type": "bind"}
    if ro == "1":
        entry["readonly"] = True
    cfg["mounts"].append(entry)
# OpenProject MCP: map the sidecar's real hostname to the host gateway so the
# container reaches the Mac-side forwarder while keeping TLS/SNI/cert valid.
op_host = os.environ.get("VIBE_OP_ADDHOST", "")
if op_host:
    if not isinstance(cfg.get("runArgs"), list):
        cfg["runArgs"] = []
    flag = "--add-host=%s:host-gateway" % op_host
    if flag not in cfg["runArgs"]:
        cfg["runArgs"].append(flag)
# task_017 shared-repos (AC18): per-shared-repo tokens reach the container via
# remoteEnv ONLY (mirroring GITHUB_TOKEN / ZOTERO_API_KEY — never containerEnv).
# The launcher exports each VIBE_SHARED_TOKEN_<slug> at top-level scope and lists
# the names in VIBE_SHARED_ENV_NAMES; add a ${localEnv:NAME} passthrough for each
# so the value crosses into the container. (GITHUB_REPO_SLUG is already a static
# remoteEnv entry in devcontainer.json, so it needs no injection here.)
shared_names = os.environ.get("VIBE_SHARED_ENV_NAMES", "").split()
if shared_names:
    if not isinstance(cfg.get("remoteEnv"), dict):
        cfg["remoteEnv"] = {}
    for name in shared_names:
        cfg["remoteEnv"][name] = "${localEnv:%s}" % name
        # Slug twin (VIBE_SHARED_SLUG_*): the helper's post-route identity
        # re-verification needs the exact declared slug in-container too.
        twin = "VIBE_SHARED_SLUG_" + name[len("VIBE_SHARED_TOKEN_"):]
        cfg["remoteEnv"][twin] = "${localEnv:%s}" % twin
with open(dst, "w") as f:
    json.dump(cfg, f, indent=2)
    f.write("\n")
PY
}

# _brain2_source / _zotero_source — echo the resolved host path for the shared
# second-brain (read-write at /brain2) and Zotero store (read-only at /zotero)
# mounts, or nothing when disabled. Path comes from ~/.vibe/config
# (VIBE_BRAIN2_PATH / VIBE_ZOTERO_PATH), defaulting to ~/brain2 and
# ~/Zotero/storage. Set the var to "off" to disable even if the dir exists.
# The mount is only injected when the resolved dir actually exists (see
# _build_override_config), so a generic vibe user without these dirs gets
# nothing — the feature is a silent no-op rather than a hard requirement.
_brain2_source() {
  local p="${VIBE_BRAIN2_PATH:-$HOME/brain2}"
  [ "$p" = "off" ] && return 0
  printf '%s' "$p"
}
_zotero_source() {
  local p="${VIBE_ZOTERO_PATH:-$HOME/Zotero/storage}"
  [ "$p" = "off" ] && return 0
  printf '%s' "$p"
}

# ── Learning subcommand internals ─────────────────────────────────────────────

_learning_init() {
  local reinit="${1:-}"
  local cfg
  cfg=$(learning_config_path)

  # Check for existing enabled config (refuse unless --reinit).
  if [ -f "$cfg" ] && [ "$reinit" != "--reinit" ]; then
    # Load existing to check if enabled.
    learning_load
    if [ "${VIBE_LEARNING_ENABLED:-}" = "true" ]; then
      echo "vibe learn: already initialized. Use 'vibe learn --reinit' to reconfigure." >&2
      exit 1
    fi
  fi

  # Prompt for library path.
  local lib_path
  while true; do
    read -rp "  Learning library path (absolute): " lib_path
    if [ -z "$lib_path" ]; then
      echo "  Path is required." >&2
      continue
    fi
    # Must be absolute.
    if [[ "$lib_path" != /* ]]; then
      echo "  Path must be absolute (start with /)." >&2
      continue
    fi
    # Parent must exist.
    local parent_dir
    parent_dir="$(dirname "$lib_path")"
    if [ ! -d "$parent_dir" ]; then
      echo "  Parent directory '$parent_dir' does not exist." >&2
      continue
    fi
    # If path doesn't exist, offer mkdir -p.
    if [ ! -d "$lib_path" ]; then
      read -rp "  '$lib_path' does not exist. Create it? [y/N]: " mkans
      mkans="${mkans:-n}"
      local mkans_lc
      mkans_lc=$(lowercase "$mkans")
      if [ "$mkans_lc" = "y" ]; then
        if ! mkdir -p "$lib_path"; then
          echo "  Failed to create directory '$lib_path'." >&2
          continue
        fi
      else
        continue
      fi
    fi
    break
  done

  # Prompt for visibility.
  local visibility
  read -rp "  Visibility [private/public] (default: private): " visibility
  visibility="${visibility:-private}"
  local vis_lc
  vis_lc=$(lowercase "$visibility")
  if [ "$vis_lc" != "private" ] && [ "$vis_lc" != "public" ]; then
    echo "  Invalid visibility '$visibility'. Must be 'private' or 'public'." >&2
    exit 1
  fi
  visibility="$vis_lc"

  local git_remote=""
  if [ "$visibility" = "public" ]; then
    # Validate git repo.
    if ! git -C "$lib_path" rev-parse --git-dir &>/dev/null 2>&1; then
      echo "vibe learn: $lib_path is not a git repo. Run 'git init' there and add a remote, then re-run vibe learn --init" >&2
      exit 1
    fi
    # Prompt for remote name and validate.
    while true; do
      read -rp "  Git remote name (e.g. origin): " git_remote
      if [ -z "$git_remote" ]; then
        echo "  Remote name is required for public visibility." >&2
        continue
      fi
      local remotes
      remotes=$(git -C "$lib_path" remote 2>/dev/null) || {
        echo "  Failed to list git remotes in '$lib_path'." >&2
        exit 1
      }
      if echo "$remotes" | grep -qxF "$git_remote"; then
        break
      else
        echo "  Remote '$git_remote' not found. Available remotes:" >&2
        echo "$remotes" >&2
      fi
    done
  fi

  # Write config.
  mkdir -p "$(dirname "$cfg")"
  {
    printf 'VIBE_LEARNING_ENABLED="true"\n'
    printf 'VIBE_LEARNING_PATH="%s"\n' "$lib_path"
    printf 'VIBE_LEARNING_VISIBILITY="%s"\n' "$visibility"
    printf 'VIBE_LEARNING_GIT_REMOTE="%s"\n' "$git_remote"
  } > "$cfg"
  chmod 600 "$cfg"

  echo "  ✓ Learning library configured."
  echo "    path       : $lib_path"
  echo "    visibility : $visibility"
  [ -n "$git_remote" ] && echo "    remote     : $git_remote"
  exit 0
}

_learning_capture() {
  local pattern="$1"

  # Require opt-in.
  learning_load
  if ! learning_is_enabled; then
    echo "vibe learn: not initialized — run 'vibe learn --init' first" >&2
    exit 1
  fi

  # Check per-project opt-out: walk from cwd toward /, stop at $HOME.
  local cwd
  cwd="$(pwd)"
  if learning_project_opted_out "$cwd"; then
    echo "vibe learn: this project has opted out of learning capture (.no-learn found)" >&2
    exit 1
  fi

  # Compute filename components.
  local ts rand entry_path
  ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  # Portable 6-char lowercase hex: use python3 (already a vibe dependency).
  rand=$(python3 -c "import os,binascii; print(binascii.hexlify(os.urandom(3)).decode())")
  entry_path=$(learning_entry_path "$VIBE_LEARNING_PATH" "$ts" "$rand")

  # Compose entry body.
  local entry_body
  entry_body=$(learning_format_entry "$ts" "$pattern")

  # Show preview and confirm.
  printf '\nWill save to %s:\n----\n%s\n----\nConfirm? [y/N]: ' "$entry_path" "$entry_body" >&2

  local confirm
  # Read one line; if stdin is closed (EOF) we get empty string.
  if ! IFS= read -r confirm; then
    # EOF
    echo "vibe learn: cancelled, nothing written" >&2
    exit 0
  fi
  # Trim whitespace.
  confirm="$(printf '%s' "$confirm" | tr -d '[:space:]')"
  local confirm_lc
  confirm_lc=$(lowercase "$confirm")
  if [ "$confirm_lc" != "y" ] && [ "$confirm_lc" != "yes" ]; then
    echo "vibe learn: cancelled, nothing written" >&2
    exit 0
  fi

  # Write the file.
  printf '%s' "$entry_body" > "$entry_path"
  echo "  ✓ Saved: $entry_path" >&2

  # Public-mode push prompt.
  if [ "${VIBE_LEARNING_VISIBILITY:-}" = "public" ]; then
    local remote="${VIBE_LEARNING_GIT_REMOTE:-origin}"
    printf 'Push to '\''%s'\''? [y/N]: ' "$remote" >&2
    local push_ans
    if ! IFS= read -r push_ans; then
      push_ans=""
    fi
    local push_lc
    push_lc=$(lowercase "$(printf '%s' "$push_ans" | tr -d '[:space:]')")
    if [ "$push_lc" = "y" ] || [ "$push_lc" = "yes" ]; then
      # Create tempfile for commit message; register cleanup. EXIT goes via
      # the dispatcher (no raw `trap ... EXIT` outside vibe_exit_hook_add);
      # INT/TERM keep a direct trap — the dispatcher owns only the EXIT slot.
      # rm -f is idempotent, so the INT→EXIT double-fire is harmless.
      local msg_tmp
      msg_tmp=$(mktemp)
      vibe_exit_hook_add "rm -f '$msg_tmp'"
      # shellcheck disable=SC2064
      trap "rm -f '$msg_tmp'" INT TERM
      learning_commit_message "$pattern" > "$msg_tmp"

      # Add the new file.
      if ! git -C "$VIBE_LEARNING_PATH" add "$entry_path" 2>&1; then
        echo "vibe learn: git add failed; entry saved locally." >&2
        exit 0
      fi
      # Commit using --file to avoid shell-arg injection.
      if ! git -C "$VIBE_LEARNING_PATH" commit --file="$msg_tmp" 2>&1; then
        echo "vibe learn: git commit failed; entry saved locally." >&2
        exit 0
      fi
      # Push.
      if ! git -C "$VIBE_LEARNING_PATH" push "$remote" 2>&1; then
        echo "vibe learn: git push failed; entry saved locally." >&2
        exit 0
      fi
      echo "  ✓ Pushed to '$remote'." >&2
    fi
  fi

  exit 0
}

# learning_handle_subcommand <args...> — top-level dispatcher for vibe learn.
# Routes --init / --reinit / <pattern> to internal sub-functions. Exits.
learning_handle_subcommand() {
  shift  # consume the "learn" argument
  local subcmd="${1:-}"

  case "$subcmd" in
    --init)
      _learning_init ""
      ;;
    --reinit)
      _learning_init "--reinit"
      ;;
    --exclude)
      _learning_exclude_project
      ;;
    --include)
      _learning_include_project
      ;;
    "")
      echo "Usage: vibe learn \"<pattern>\"  — save a cross-project pattern" >&2
      echo "       vibe learn --init       — set up the learning library" >&2
      echo "       vibe learn --exclude    — opt this project out (creates .no-learn)" >&2
      echo "       vibe learn --include    — opt this project back in (removes .no-learn)" >&2
      echo "" >&2
      echo "Run on the host shell from the project directory — not inside the container." >&2
      exit 1
      ;;
    --*)
      echo "vibe learn: unknown option '$subcmd'" >&2
      exit 1
      ;;
    *)
      _learning_capture "$subcmd"
      ;;
  esac
}

# _learning_exclude_project — create a .no-learn marker in the current
# directory so vibe learn capture and the /learnings mount skip this project.
# Idempotent. Refuses to write if cwd is $HOME (would block all projects).
_learning_exclude_project() {
  local cwd
  cwd="$(pwd)"
  if [ -n "${HOME:-}" ] && [ "$cwd" = "$HOME" ]; then
    echo "vibe learn --exclude: refusing to mark \$HOME — that would opt out of every project" >&2
    exit 1
  fi
  local marker="$cwd/.no-learn"
  if [ -e "$marker" ]; then
    echo "vibe learn: already excluded ($marker exists)"
  else
    : > "$marker"
    echo "vibe learn: this project is now excluded (created $marker)"
  fi
  exit 0
}

# _learning_include_project — remove .no-learn marker(s) from the current
# directory (also removes legacy .vibe-no-learn). Idempotent.
_learning_include_project() {
  local cwd removed=0
  cwd="$(pwd)"
  for marker_name in .no-learn .vibe-no-learn; do
    local marker="$cwd/$marker_name"
    if [ -e "$marker" ]; then
      rm -f "$marker"
      echo "vibe learn: removed $marker"
      removed=1
    fi
  done
  if [ "$removed" -eq 0 ]; then
    echo "vibe learn: this project was not excluded (no marker found)"
  else
    echo "vibe learn: this project is now included again"
  fi
  exit 0
}

# ── Shared-repos helpers (task_017 cycle 1) ───────────────────────────────────
# Declaration file: <project>/.vibe-repos, COMMITTED (one `<owner>/<repo>
# <ro|rw>` line per repo, mode optional/default ro). Machine registry:
# ~/.vibe/repos (REPOS_REGISTRY_FILE, `slug=path` lines, chmod 600). Every
# helper here is defined above the VIBE_SOURCE_ONLY guard so smoke-test.py
# can unit-test them by sourcing the launcher directly. All read paths follow
# the lookup_token / auto_resume_field fail-safe discipline: a missing file,
# an unmatched key, or a malformed value echoes NOTHING rather than raising
# an error — callers treat empty output as "not configured", never as a bug.

# is_valid_repo_slug <slug> — true iff slug is exactly `owner/repo` in the
# charset [A-Za-z0-9._-]+/[A-Za-z0-9._-]+ (one slash, no path traversal, no
# shell metacharacters). Shared by shared_repos_parse (reading the committed
# declaration file) and `vibe repos add` (reading a CLI arg) so a hand-edited
# file and the CLI enforce the identical rule.
is_valid_repo_slug() {
  [[ "${1:-}" =~ ^[A-Za-z0-9._-]+/[A-Za-z0-9._-]+$ ]]
}

# shared_repo_basename <slug> — echoes the mount-point basename: the part of
# slug after the last '/'. Pure string op, no I/O.
shared_repo_basename() {
  printf '%s' "${1##*/}"
}

# shared_repo_env_name <slug> — echoes the full per-repo token env var name:
# VIBE_SHARED_TOKEN_<SANITISED>, sanitisation = uppercase then every
# non-alphanumeric character (including slug's own '/') becomes '_'. E.g.
# andeyePro/andeyePro -> VIBE_SHARED_TOKEN_ANDEYEPRO_ANDEYEPRO. Pure string
# transform; collision detection between two configured slugs sanitising to
# the same name is `vibe repos add`'s job (see _repos_add below), not this
# helper's.
shared_repo_env_name() {
  local upper
  upper=$(printf '%s' "$1" | tr '[:lower:]' '[:upper:]')
  printf 'VIBE_SHARED_TOKEN_%s' "$(printf '%s' "$upper" | tr -c 'A-Z0-9' '_')"
}

# shared_repos_parse <file> — reads a .vibe-repos declaration file, echoing
# one "slug mode" line per VALID entry (mode is always "ro" or "rw", defaulted
# to "ro" when the file omits it). Comments (lines starting with `#`, after
# whitespace-trimming) and blank lines are skipped silently. A malformed line
# (bad slug charset, bad mode, or unexpected trailing content) is skipped
# with a one-line stderr warning naming the line number and offending text —
# never aborts the read, so one bad hand-edited line can't hide every other
# declaration. Missing file echoes nothing (fail-safe). `read`'s own
# whitespace-splitting does the trimming; no sed/awk needed.
shared_repos_parse() {
  local file="$1"
  [ -f "$file" ] || return 0
  local lineno=0 raw slug mode extra
  while IFS= read -r raw || [ -n "$raw" ]; do
    lineno=$((lineno + 1))
    slug="" mode="" extra=""
    read -r slug mode extra <<< "$raw"
    case "$slug" in
      ''|'#'*) continue ;;  # blank or (whitespace-then-)comment line
    esac
    if ! is_valid_repo_slug "$slug"; then
      echo "vibe: .vibe-repos:${lineno}: malformed slug '${slug}' — skipped" >&2
      continue
    fi
    mode="${mode:-ro}"
    case "$mode" in
      ro|rw) ;;
      *)
        echo "vibe: .vibe-repos:${lineno}: invalid mode '${mode}' for '${slug}' — skipped" >&2
        continue
        ;;
    esac
    if [ -n "$extra" ]; then
      echo "vibe: .vibe-repos:${lineno}: unexpected content after mode for '${slug}' — skipped" >&2
      continue
    fi
    echo "$slug $mode"
  done < "$file"
}

# repos_registry_lookup <slug> — echoes the registered local checkout path
# for <slug> from REPOS_REGISTRY_FILE (`slug=path` lines), or nothing if
# unregistered, the file is missing, or the resolved path fails validation
# (contains a newline or a double-quote, or isn't absolute — a hand-trampled
# registry line silently fails to resolve rather than propagating garbage
# into a mount path). Mirrors lookup_token's `cut -d= -f2-` (not `-f2`) so a
# path containing '=' is returned whole.
repos_registry_lookup() {
  local slug="$1"
  [ -f "$REPOS_REGISTRY_FILE" ] || return 0
  is_valid_repo_slug "$slug" || return 0
  local path
  # Fixed-string key match (see lookup_token) — a committed slug must never
  # regex-match a different registry entry.
  path=$(awk -v k="${slug}" 'index($0, k"=")==1 {print substr($0, length(k)+2)}' "$REPOS_REGISTRY_FILE" 2>/dev/null | tail -1) || return 0
  [ -z "$path" ] && return 0
  case "$path" in
    *$'\n'*|*'"'*|*/../*|../*|*/..) return 0 ;;
  esac
  case "$path" in
    /*) ;;
    *) return 0 ;;
  esac
  printf '%s' "$path"
}

# repos_registry_save <slug> <path> — writes/updates the `slug=path` entry in
# REPOS_REGISTRY_FILE (chmod 600, like TOKENS_FILE). Mirrors save_token's
# grep-filter-then-rewrite pattern against a different file.
repos_registry_save() {
  local slug="$1" path="$2"
  mkdir -p "$(dirname "$REPOS_REGISTRY_FILE")"
  touch "$REPOS_REGISTRY_FILE"
  local tmp
  tmp=$(mktemp)
  awk -v k="${slug}" 'index($0, k"=")!=1' "$REPOS_REGISTRY_FILE" > "$tmp" || true
  echo "${slug}=${path}" >> "$tmp"
  mv "$tmp" "$REPOS_REGISTRY_FILE"
  chmod 600 "$REPOS_REGISTRY_FILE"
}

# repos_registry_remove <slug> — drops <slug>'s entry from REPOS_REGISTRY_FILE
# (used by `vibe repos remove --purge`). No-op when the file or the key is
# absent.
repos_registry_remove() {
  local slug="$1"
  [ -f "$REPOS_REGISTRY_FILE" ] || return 0
  local tmp
  tmp=$(mktemp)
  awk -v k="${slug}" 'index($0, k"=")!=1' "$REPOS_REGISTRY_FILE" > "$tmp" || true
  mv "$tmp" "$REPOS_REGISTRY_FILE"
  chmod 600 "$REPOS_REGISTRY_FILE"
}

# ── Per-workspace shared-repo authorisation (acks) ───────────────────────────
# ~/.vibe/repos-acks (chmod 600, machine-local, never PR-controllable) records
# which WORKSPACES the user has authorised each shared repo for — the consent
# layer the committed .vibe-repos cannot provide on its own: a malicious PR
# can add a declaration line, but only `vibe repos add` run BY THE USER in
# that project writes the matching ack, so an unacked declaration never
# mounts and never triggers host-side sidecar writes (security-review
# finding, task_017 C1). Line format: <slug>=<workspace-abs-path>, matched
# whole-line fixed-string (grep -qxF — no regex surface). Paths are recorded
# as given by pwd -P at add time; a symlinked launch path that differs from
# the add-time path shows as unacked (worst case: one extra warning and a
# re-run of `vibe repos add` — fail-safe toward not mounting).
REPOS_ACKS_FILE="$HOME/.vibe/repos-acks"

# shared_repo_acked <slug> <workspace> — true iff this exact pair is recorded.
shared_repo_acked() {
  local slug="$1" ws="$2"
  [ -f "$REPOS_ACKS_FILE" ] || return 1
  grep -qxF "${slug}=${ws}" "$REPOS_ACKS_FILE"
}

# shared_repo_ack <slug> <workspace> — records the pair (idempotent).
shared_repo_ack() {
  local slug="$1" ws="$2"
  mkdir -p "$(dirname "$REPOS_ACKS_FILE")"
  touch "$REPOS_ACKS_FILE"
  chmod 600 "$REPOS_ACKS_FILE"
  shared_repo_acked "$slug" "$ws" && return 0
  printf '%s=%s\n' "$slug" "$ws" >> "$REPOS_ACKS_FILE"
}

# shared_repo_ensure_signals <checkout> — idempotently ensures the
# .vibe-signals/ sidecar exists under <checkout> (host-side `mkdir -p`, so
# it's owned by the invoking user rather than whatever uid Docker's bind
# auto-vivification would pick) AND that .vibe-signals/ is gitignored in that
# checkout's OWN .gitignore — a second, independent owner from
# ensure_project_gitignore's managed block (install-claude-extras.sh), needed
# because a shared checkout may not itself be a vibe project and may never
# have launched vibe. Called from BOTH `vibe repos add` (registration time,
# see _repos_add) and shared_repos_scan (defensively, before any bind
# referencing the sidecar) — both call sites are guarded/idempotent, so
# calling this twice (or a hundred times) across a launch is harmless.
# Never aborts the caller on an unwritable checkout (read-only mount,
# offline network volume, etc): returns 1 so the caller can demote the repo
# to registered-but-broken (reason "sidecar unwritable") instead of tripping
# `set -e`. Returns 0 on success.
shared_repo_ensure_signals() {
  local checkout="$1" sidecar gitignore
  [ -n "$checkout" ] || return 1
  sidecar="$checkout/.vibe-signals"
  mkdir -p "$sidecar" 2>/dev/null || return 1
  [ -w "$sidecar" ] || return 1

  gitignore="$checkout/.gitignore"
  if [ -f "$gitignore" ]; then
    if ! grep -qxF ".vibe-signals/" "$gitignore" 2>/dev/null; then
      echo ".vibe-signals/" >> "$gitignore" 2>/dev/null || return 1
    fi
  else
    echo ".vibe-signals/" > "$gitignore" 2>/dev/null || return 1
  fi
  return 0
}

# shared_repos_scan <workspace> — the SINGLE classification pass (tags M mounted / B broken / N never-registered / U declared-but-unauthorised-for-this-workspace) shared by
# `vibe repos list`, the launch header, the runtime manifest, and
# _build_override_config's mount-triple assembly (deliberate: one code path
# deciding what's mounted means the header can never disagree with what
# actually got bind-mounted). Reads <workspace>/.vibe-repos via
# shared_repos_parse and, for each validated (slug, mode) line, echoes
# EXACTLY ONE of:
#   M <name> <bindmode> <slug> <checkout>   — resolved & mounted
#   B <slug> <reason...>                    — registered but broken
#   N <slug>                                — never registered on this machine
# The M/B/N split is what lets AC4's header distinguish "no registry entry"
# (N — total silence, the community-contributor case) from "registry entry
# broken" (B — loud warning) as two different branches below, not two
# renderings of one branch. bindmode is hard-pinned "ro" in cycle 1
# regardless of the declared mode (the mode field parses now so cycle 2's
# rw-intent + lock logic has somewhere to read from; only cycle 2 wires it to
# the actual bind flag). Side effect: a repo that reaches shared_repo_ensure_
# signals gets its sidecar mkdir'd/gitignored here; a failure there demotes
# it to B ("sidecar unwritable") rather than aborting — sibling repos are
# still processed (never a hard failure partway through the scan).
shared_repos_scan() {
  local workspace="$1"
  local decl="$workspace/.vibe-repos"
  local seen_names="" slug mode name path bindmode

  while read -r slug mode; do
    [ -n "$slug" ] || continue

    name="$(shared_repo_basename "$slug")"

    # Reserved dot-prefixed basenames: the .vibe-signals sidecar namespace
    # lives beside repo mounts, so a repo named e.g. `.foo` would collide
    # with it. `vibe repos add` rejects these at registration; this is the
    # defensive re-check for a hand-edited .vibe-repos that slipped one in.
    case "$name" in
      .*)
        echo "vibe: shared repo '$slug': mount skipped - basenames beginning with '.' are reserved" >&2
        echo "B $slug reserved dot-prefixed name '$name'"
        continue
        ;;
    esac

    # Basename collision: only matters against a name that ALREADY resolved
    # to a real mount (see the `seen_names` update at the bottom) — a name
    # clash against a repo that itself never mounts isn't a real conflict.
    if printf '%s\n' "$seen_names" | grep -qxF "$name"; then
      echo "B $slug basename '$name' collides with another declared repo"
      continue
    fi

    path="$(repos_registry_lookup "$slug")"
    if [ -z "$path" ]; then
      echo "N $slug"
      continue
    fi

    # Consent gate: registered on this machine, but this WORKSPACE was never
    # authorised (no ack) — a committed .vibe-repos line alone must never
    # mount a repo or write into its checkout. U is loud downstream (header +
    # list), unlike N's deliberate silence: an unacked-but-registered repo is
    # the maintainer's own machine misconfigured or a PR-injected line, and
    # both deserve a warning.
    if ! shared_repo_acked "$slug" "$workspace"; then
      echo "U $slug"
      continue
    fi

    if [ ! -e "$path/.git" ]; then
      echo "B $slug path missing or not a git checkout ($path)"
      continue
    fi

    # Token-absent is a WARNING, not a mount-blocker, from C4 on (AC18 — the
    # sanctioned relaxation recorded in the spec's C4 preamble): an ro bind of
    # a LOCAL checkout needs no token at all; only fetch/push do. The launch
    # path warns per-launch at the token-export loop, and `vibe repos list`
    # appends a no-PAT note per mounted repo (see _repos_list).
    if ! shared_repo_ensure_signals "$path"; then
      echo "B $slug sidecar unwritable ($path/.vibe-signals)"
      continue
    fi

    seen_names="$seen_names
$name"
    # Effective mode: declared intent resolved against the single-writer
    # lock (C2). resolve_mode is a pure idempotent re-read here — the lock
    # was taken (or refused, queueing a loud fallback warning) once, in the
    # main shell, by shared_repos_apply_rw_intents BEFORE any caller of this
    # scan runs; so list/header/manifest/mounts all report the same answer
    # and a subshell invocation can never double-acquire.
    bindmode="$(shared_repo_resolve_mode "$slug" "$path" "$mode")"
    echo "M $name $bindmode $slug $path"
  done < <(shared_repos_parse "$decl")
}

# shared_repos_manifest_lines <scan_output> — pure filter: given
# shared_repos_scan's stdout, echoes the AC5 runtime-manifest lines ("name
# mode slug", one per MOUNTED repo). No I/O — the caller redirects this to
# the manifest file.
shared_repos_manifest_lines() {
  local scan="$1" scan_line name bindmode slug rest
  while IFS= read -r scan_line; do
    case "$scan_line" in
      M\ *)
        read -r name bindmode slug rest <<< "${scan_line#M }"
        printf '%s %s %s\n' "$name" "$bindmode" "$slug"
        ;;
    esac
  done <<< "$scan"
}

# ── Shared-repos subcommand internals (`vibe repos ...`) ─────────────────────
# Operates on the CURRENT project directory via `pwd`, mirroring the learning
# subcommand's `_learning_exclude_project` (not $WORKSPACE, which only exists
# after the full launch flow resolves it — these subcommands dispatch and
# exit before that point, see the dispatch block below).

_repos_usage() {
  echo "Usage: vibe repos add [--rw] <owner/repo> [path]" >&2
  echo "       vibe repos remove <owner/repo> [--purge]" >&2
  echo "       vibe repos list" >&2
  exit 1
}

# _repos_add <slug> [path] — validates <slug>, resolves/validates the local
# checkout path (prompts if omitted; must contain .git), rejects a reserved
# dot-prefixed basename or a basename/token-env collision against any OTHER
# already-registered slug, writes the registry entry, ensures the signals
# sidecar (+ its gitignore) in the checkout, appends the declaration to this
# project's .vibe-repos if not already present, and mints a token if none is
# stored yet. Exits non-zero with a one-line reason on any validation
# failure; exits 0 with a relaunch reminder on success.
_repos_add() {
  # `--rw` (AC8) may appear before or after the slug; it sets the declared
  # mode to rw — both on a fresh declaration and on one that already exists
  # (shared_repo_declaration_set_mode flips an existing line in place).
  local slug="" path_arg="" mode="ro" arg
  for arg in "$@"; do
    case "$arg" in
      --rw) mode="rw" ;;
      *)
        if [ -z "$slug" ]; then slug="$arg"
        elif [ -z "$path_arg" ]; then path_arg="$arg"
        else _repos_usage; fi
        ;;
    esac
  done

  if [ -z "$slug" ]; then
    _repos_usage
  fi
  if ! is_valid_repo_slug "$slug"; then
    echo "vibe repos add: '$slug' is not a valid owner/repo slug" >&2
    exit 1
  fi

  local name
  name="$(shared_repo_basename "$slug")"
  case "$name" in
    .*)
      echo "vibe repos add: repo basenames beginning with '.' are reserved (the .vibe-signals sidecar namespace lives beside repo mounts)" >&2
      exit 1
      ;;
  esac

  # Collision checks against every OTHER already-registered slug: same mount
  # basename, or same sanitised token env name.
  local env_name
  env_name="$(shared_repo_env_name "$slug")"
  if [ -f "$REPOS_REGISTRY_FILE" ]; then
    local existing_slug other_name other_env
    while IFS='=' read -r existing_slug _; do
      [ -n "$existing_slug" ] || continue
      [ "$existing_slug" = "$slug" ] && continue
      other_name="$(shared_repo_basename "$existing_slug")"
      if [ "$other_name" = "$name" ]; then
        echo "vibe repos add: basename '$name' already used by registered repo '$existing_slug' — mount points must be unique" >&2
        exit 1
      fi
      other_env="$(shared_repo_env_name "$existing_slug")"
      if [ "$other_env" = "$env_name" ]; then
        echo "vibe repos add: '$slug' sanitises to the same token env var ($env_name) as already-registered '$existing_slug'" >&2
        exit 1
      fi
    done < "$REPOS_REGISTRY_FILE"
  fi

  # Resolve the local checkout path.
  local path="$path_arg"
  if [ -z "$path" ]; then
    read -rp "  Local path for $slug: " path
  fi
  case "$path" in
    /*) ;;
    *) path="$(cd "$path" 2>/dev/null && pwd -P)" || path="" ;;
  esac
  if [ -z "$path" ] || [ ! -d "$path" ]; then
    echo "vibe repos add: '${path_arg:-$path}' is not a directory" >&2
    exit 1
  fi
  if [ ! -e "$path/.git" ]; then
    echo "vibe repos add: '$path' has no .git — point at an existing local checkout of $slug" >&2
    echo "    (vibe repos add doesn't clone; if you don't have it yet: git clone https://github.com/$slug.git)" >&2
    exit 1
  fi

  repos_registry_save "$slug" "$path"

  if ! shared_repo_ensure_signals "$path"; then
    echo "  ⚠ could not create $path/.vibe-signals (unwritable checkout?) — will show as BROKEN until fixed" >&2
  fi

  if _vibe_repos_decl_has "$(pwd -P)/.vibe-repos" "$slug"; then
    # Already declared: --rw upgrades the existing line's mode in place
    # (add without --rw leaves an existing rw declaration alone — running
    # plain `add` again must never silently DOWNGRADE an intent).
    [ "$mode" = "rw" ] && shared_repo_declaration_set_mode "$(pwd -P)/.vibe-repos" "$slug" "rw"
  else
    _vibe_repos_decl_append "$(pwd -P)/.vibe-repos" "$slug" "$mode"
  fi
  # The ack IS the consent act: this user, this machine, this project.
  shared_repo_ack "$slug" "$(pwd -P)"

  if [ -z "$(lookup_token "$slug")" ]; then
    setup_token "$slug"
  fi

  echo "  ✓ $slug registered at $path and declared in .vibe-repos"
  echo "    Relaunch (vibe) for the mount to take effect."
  exit 0
}

# _vibe_repos_decl_has <file> <slug> — true iff <slug> is already declared
# (any mode) in <file>, per shared_repos_parse's validated view.
_vibe_repos_decl_has() {
  local file="$1" slug="$2"
  shared_repos_parse "$file" 2>/dev/null | cut -d' ' -f1 | grep -qxF "$slug"
}

# _vibe_repos_decl_append <file> <slug> <mode> — appends "<slug> <mode>" as a
# new line (creating the file if absent). No-op if <slug> is already
# declared (any mode) — see _vibe_repos_decl_has.
_vibe_repos_decl_append() {
  local file="$1" slug="$2" mode="$3"
  _vibe_repos_decl_has "$file" "$slug" && return 0
  printf '%s %s\n' "$slug" "$mode" >> "$file"
}

# _vibe_repos_decl_remove <file> <slug> — removes the line(s) declaring
# <slug> from <file>, preserving every other line (comments, blanks, other
# entries) untouched. No-op if the file or the slug isn't present.
_vibe_repos_decl_remove() {
  local file="$1" slug="$2"
  [ -f "$file" ] || return 0
  local tmp
  tmp=$(mktemp)
  awk -v k="${slug}" '!(index($0, k" ")==1 || $0==k)' "$file" > "$tmp" || true
  mv "$tmp" "$file"
}

# _repos_remove <slug> [--purge] — removes <slug>'s declaration line from
# this project's .vibe-repos (registry entry retained by default — other
# projects may use it). --purge also drops the machine registry entry and,
# if a token is stored, offers to delete it too. Exits non-zero with a
# one-line reason on validation failure; exits 0 on success.
_repos_remove() {
  local slug="${1:-}" purge=""
  if [ -z "$slug" ]; then
    _repos_usage
  fi
  shift
  case "${1:-}" in
    --purge) purge=1 ;;
    "") ;;
    *)
      echo "vibe repos remove: unknown option '$1'" >&2
      exit 1
      ;;
  esac
  if ! is_valid_repo_slug "$slug"; then
    echo "vibe repos remove: '$slug' is not a valid owner/repo slug" >&2
    exit 1
  fi

  local decl
  decl="$(pwd -P)/.vibe-repos"
  if ! _vibe_repos_decl_has "$decl" "$slug"; then
    echo "vibe repos remove: '$slug' is not declared in this project's .vibe-repos" >&2
    exit 1
  fi
  _vibe_repos_decl_remove "$decl" "$slug"
  echo "  ✓ $slug removed from this project's .vibe-repos"

  if [ -n "$purge" ]; then
    repos_registry_remove "$slug"
    echo "  ✓ $slug removed from the machine registry (~/.vibe/repos)"
    if [ -n "$(lookup_token "$slug")" ]; then
      if ask_yes_no "Also delete the stored token for $slug?" n; then
        remove_token "$slug"
        echo "  ✓ token deleted"
      fi
    fi
  fi

  echo "    Relaunch (vibe) for the change to take effect."
  exit 0
}

# _repos_list — shows every repo declared in this project's .vibe-repos with
# its resolution status: "mounted <ro|rw> at /repos/<name>", "BROKEN:
# <reason>", or "not configured on this machine" — driven entirely by
# shared_repos_scan's M/B/N tags (see its comment) so list can never disagree
# with what a launch would actually mount. Always exits 0 (listing has no
# validation-failure mode).
_repos_list() {
  local workspace decl
  workspace="$(pwd -P)"
  decl="$workspace/.vibe-repos"
  if [ ! -f "$decl" ]; then
    echo "  No .vibe-repos declaration in this project."
    exit 0
  fi

  local scan_line found=0 name mode slug path reason
  while IFS= read -r scan_line; do
    case "$scan_line" in
      M\ *)
        read -r name mode slug path <<< "${scan_line#M }"
        if [ -z "$(lookup_token "$slug")" ]; then
          echo "  $slug - mounted $mode at /repos/$name (no PAT staged - fetch/push will fail; run: vibe repos add $slug)"
        else
          echo "  $slug - mounted $mode at /repos/$name"
        fi
        found=1
        ;;
      B\ *)
        read -r slug reason <<< "${scan_line#B }"
        echo "  $slug - BROKEN: $reason"
        found=1
        ;;
      N\ *)
        read -r slug <<< "${scan_line#N }"
        echo "  $slug - not configured on this machine"
        found=1
        ;;
      U\ *)
        read -r slug <<< "${scan_line#U }"
        echo "  $slug - declared but not authorised for this project (run: vibe repos add $slug)"
        found=1
        ;;
    esac
  done < <(shared_repos_scan "$workspace")

  [ "$found" -eq 1 ] || echo "  .vibe-repos declares nothing (every line was blank, a comment, or malformed - see warnings above)."
  exit 0
}

# repos_handle_subcommand <args...> — top-level dispatcher for `vibe repos`,
# invoked from its own dispatch block (mirrors `learn`'s, see the block
# immediately before parse_vibe_args below). Every branch below exits inside
# the sub-function it calls; nothing here relies on its own return value.
repos_handle_subcommand() {
  shift  # consume "repos"
  local subcmd="${1:-}"
  case "$subcmd" in
    add)
      shift
      _repos_add "$@"
      ;;
    remove)
      shift
      _repos_remove "$@"
      ;;
    list)
      _repos_list
      ;;
    "")
      _repos_usage
      ;;
    *)
      echo "vibe repos: unknown subcommand '$subcmd'" >&2
      exit 1
      ;;
  esac
}

# ── Learning mount helper ─────────────────────────────────────────────────────

# _build_override_config <workspace_abs_path> — collects the bind mounts that
# apply to this workspace (learning library at /learnings, shared brain2 at
# /brain2 rw, Zotero store at /zotero ro) and, if any apply, generates the
# per-session override JSON under $HOME/.vibe/run/ and echoes its path. If none
# apply, echoes the default $DEVCONTAINER_DIR/devcontainer.json path unchanged.
# Always exits 0.
# Hostname (no scheme/port/path) of the OpenProject MCP, derived from the staged
# OPENPROJECT_MCP_URL. Empty when the OP MCP isn't configured. Used both to start
# the forwarder and to inject the container's --add-host.
_op_mcp_host() {
  local url="${OPENPROJECT_MCP_URL:-}"
  [ -n "$url" ] && [ -n "${OPENPROJECT_MCP_BEARER:-}" ] || return 0
  local rest="${url#*://}"
  local host="${rest%%/*}"
  printf '%s' "${host%%:*}"
}

# Start the Mac-side TCP forwarder (127.0.0.1:$OP_MCP_FWD_PORT -> <op-host>:443)
# so the non-tailnet container can reach the tailnet-only sidecar via --add-host.
# Unprivileged, lifecycle-detached, and idempotent: the forwarder self-exits if
# the port is already bound, so repeated/concurrent vibe launches are safe. A
# missing creds / missing python3 just no-ops (the in-container registration is
# reachability-gated, so nothing breaks when the forwarder isn't up).
_ensure_op_forwarder() {
  local host
  host="$(_op_mcp_host)"
  [ -n "$host" ] || return 0
  command -v python3 >/dev/null 2>&1 || {
    echo "  note: python3 not found - OP MCP forwarder not started (/op unavailable)"
    return 0
  }
  local fwd="$VIBE_REPO_DIR/op-mcp-forwarder.py"
  [ -f "$fwd" ] || return 0
  mkdir -p "$HOME/.vibe"
  nohup python3 "$fwd" "$OP_MCP_FWD_PORT" "$host" 443 \
    >>"$HOME/.vibe/op-mcp-forwarder.log" 2>&1 &
  disown 2>/dev/null || true
}

_build_override_config() {
  local workspace="$1"
  local default_cfg="$DEVCONTAINER_DIR/devcontainer.json"

  learning_load

  # Collect (source, target, ro) triples for every mount that applies.
  local mount_args=()

  # Learning library — read-only at /learnings (gated by learning.config +
  # per-project .no-learn, same as before).
  if learning_should_mount "$workspace"; then
    mount_args+=("$VIBE_LEARNING_PATH" "/learnings" "1")
  fi

  # Shared second brain — read-write at /brain2. Only when the resolved dir
  # exists. Skip when the workspace IS the brain2 repo (the gardener):
  # /workspace already binds it, so a /brain2 mount would be a redundant
  # self-mount.
  local brain2
  brain2="$(_brain2_source)"
  if [ -n "$brain2" ] && [ -d "$brain2" ]; then
    local canon_ws canon_brain2
    canon_ws="$(cd "$workspace" 2>/dev/null && pwd -P || echo "$workspace")"
    canon_brain2="$(cd "$brain2" 2>/dev/null && pwd -P || echo "$brain2")"
    if [ "$canon_ws" != "$canon_brain2" ]; then
      mount_args+=("$brain2" "/brain2" "0")
    fi
  fi

  # Zotero store — read-only at /zotero. Only when the resolved dir exists.
  # Keep this a standalone mount (not nested under another bind) to dodge the
  # Docker Desktop VirtioFS nested-mount regression.
  local zotero
  zotero="$(_zotero_source)"
  if [ -n "$zotero" ] && [ -d "$zotero" ]; then
    mount_args+=("$zotero" "/zotero" "1")
  fi

  # Shared repos declared in this project's .vibe-repos (task_017 cycle 1).
  # Each resolved repo contributes TWO bind triples: the checkout itself
  # (ro, hard-pinned in cycle 1 — rw arrives in cycle 2's lock) at
  # /repos/<name>, and its .vibe-signals/ sidecar, ALWAYS rw even when the
  # code mount is ro, at /repos/.signals/<name> — that's what lets a
  # read-only session file an rw claim (see .vs/spec.md's Pinned-names
  # section). shared_repos_scan is the single classification pass shared
  # with the header/manifest printed later in the launch flow; calling it
  # again here (inside this function's own command-substitution subshell —
  # the caller assigns this function's stdout to OVERRIDE_CONFIG) is safe and
  # idempotent — its side effects are real mkdir/gitignore writes, which
  # persist past a subshell exiting. Only EXPORTED SHELL VARIABLES die with a
  # subshell (see the parent-shell config-load comment above this function);
  # nothing here relies on that.
  local scan_line name bindmode slug checkout ro_flag
  while IFS= read -r scan_line; do
    case "$scan_line" in
      M\ *)
        read -r name bindmode slug checkout <<< "${scan_line#M }"
        ro_flag="0"
        [ "$bindmode" = "ro" ] && ro_flag="1"
        mount_args+=("$checkout" "/repos/$name" "$ro_flag")
        mount_args+=("$checkout/.vibe-signals" "/repos/.signals/$name" "0")
        ;;
    esac
  done < <(shared_repos_scan "$workspace")

  # OpenProject MCP: the container resolves the sidecar's real hostname to the
  # Mac forwarder via --add-host (so TLS/SNI/cert stay valid end-to-end). Empty
  # unless the OP MCP is configured.
  local op_host
  op_host="$(_op_mcp_host)"

  # Nothing to inject → use the base config untouched (preserves prior
  # behaviour for projects with no learning/brain2/zotero AND no OP MCP).
  if [ "${#mount_args[@]}" -eq 0 ] && [ -z "$op_host" ]; then
    echo "$default_cfg"
    return 0
  fi

  # Compute a sha1 of the workspace path for a stable per-workspace filename.
  local sha1
  sha1=$(printf '%s' "$workspace" | sha1sum | cut -c1-40 2>/dev/null \
         || printf '%s' "$workspace" | shasum | cut -c1-40 2>/dev/null \
         || printf '%s' "$workspace" | cksum | awk '{print $1}')

  local run_dir="$HOME/.vibe/run"
  mkdir -p "$run_dir"
  local dst="$run_dir/devcontainer-${sha1}.json"

  VIBE_OP_ADDHOST="$op_host" \
    render_devcontainer_with_mounts "$default_cfg" "$dst" "${mount_args[@]}"
  echo "$dst"
}

# ── Image-drift detection ─────────────────────────────────────────────────────
# Defined here, ABOVE the VIBE_SOURCE_ONLY guard, so smoke-test.py can
# unit-test them by sourcing with VIBE_SOURCE_ONLY=1 and a stubbed docker().

# image_drift_needs_recreate <workspace> <image_tag>
# Emits "1" on stdout iff the existing devcontainer for <workspace> was built
# from an image that differs from the current <image_tag> image (drift).
# Emits nothing when there is no container, or the container is current.
# All docker calls are fail-safe: non-zero exit or empty output degrades to a
# defined verdict rather than aborting the script (set -euo pipefail safe).
# The --remove-existing-container flag (drift trigger) is appended by the
# caller via remove_existing_flag; this function only detects the condition.
image_drift_needs_recreate() {
  # Step 1: find a container for this workspace via its devcontainer label.
  # Capture ALL ids then take the first line with parameter expansion to
  # avoid a | head pipe (which causes SIGPIPE / exit 141 under pipefail).
  local cids cid
  cids=$(docker ps -aq --filter "label=devcontainer.local_folder=$1" 2>/dev/null) || cids=""
  cid="${cids%%$'\n'*}"
  [ -z "$cid" ] && return 0  # no container - nothing to recreate

  # Step 2: container's image reference (a digest or repo:tag string).
  local container_ref
  container_ref=$(docker inspect --format '{{.Image}}' "$cid" 2>/dev/null) || container_ref=""
  [ -z "$container_ref" ] && return 0  # anomalous - can't determine

  # Step 3: canonical config id of the CURRENT image tag.
  local current_id
  current_id=$(docker image inspect --format '{{.Id}}' "$2" 2>/dev/null) || current_id=""
  [ -z "$current_id" ] && return 0  # no current image to recreate from

  # Step 4: normalise the container's image reference to a config id.
  # Re-resolving via image inspect unifies classic Docker (config digest) and
  # containerd image store (which may return a manifest digest in {{.Image}}).
  # If the container's source image has been pruned/superseded and is no
  # longer resolvable, that IS drift - emit 1 so the container is recreated.
  local container_id
  container_id=$(docker image inspect --format '{{.Id}}' "$container_ref" 2>/dev/null) || container_id=""
  if [ -z "$container_id" ]; then
    echo 1  # source image gone - superseded; recreate from current image
    return 0
  fi

  # Step 5: compare normalised ids; emit 1 only on drift.
  [ "$container_id" != "$current_id" ] && echo 1
  return 0
}

# remove_existing_flag <rebuild_bool> <drift_marker>
# Pure decision function (no docker). Echoes "--remove-existing-container"
# exactly once when $1 is "true" (--rebuild) OR $2 is non-empty (drift).
# Echoes nothing when neither condition holds. The at-most-once guarantee
# satisfies AC4 regardless of both inputs being set simultaneously.
remove_existing_flag() {
  if [ "$1" = "true" ] || [ -n "$2" ]; then
    echo "--remove-existing-container"
  fi
}

# ── Argv parser ───────────────────────────────────────────────────────────────
# parse_vibe_args "$@" - parse flags and an optional project positional in any
# order. Sets globals REBUILD / CONTINUE / RESUME / RESUME_UID / PROJECT_ARG /
# MODEL_ARG.
# Errors out on unknown flags or a second positional. Defined above the
# VIBE_SOURCE_ONLY guard so smoke-test.py can source it. Handles --list and
# --help inline (both exit, as before).
parse_vibe_args() {
  REBUILD=false
  CONTINUE=false
  RESUME=false
  RESUME_UID=""
  PROJECT_ARG=""
  MODEL_ARG=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --rebuild) REBUILD=true; shift ;;
      --continue) CONTINUE=true; shift ;;
      --fable) MODEL_ARG="$FABLE_MODEL_ID"; shift ;;
      --model)
        shift
        if ! is_model_id "${1:-}"; then
          echo "--model needs a model id (e.g. claude-fable-5), got: '${1:-}'" >&2
          exit 1
        fi
        MODEL_ARG="$1"; shift
        ;;
      --resume)
        RESUME=true; shift
        if is_uuid "${1:-}"; then
          RESUME_UID="$1"; shift
        fi
        ;;
      --list)
        echo "Projects in $PROJECTS_DIR:"
        ls "$PROJECTS_DIR"
        exit 0
        ;;
      --version|-V) print_version ;;
      --help|-h) usage ;;
      --*)
        echo "Unknown flag: $1" >&2
        exit 1
        ;;
      *)
        if [ -n "$PROJECT_ARG" ]; then
          echo "Unexpected extra argument: $1 (already have project '$PROJECT_ARG')" >&2
          exit 1
        fi
        PROJECT_ARG="$1"
        shift
        ;;
    esac
  done
}

# Allow smoke-test.py to source this file for pure unit-testing of helpers
# without running the main launch logic below.
[ "${VIBE_SOURCE_ONLY:-}" = "1" ] && return 0 2>/dev/null

# ── Learn subcommand dispatch ─────────────────────────────────────────────────
# Must be BEFORE the --* flag-parser loop. Dispatches and exits; does NOT enter
# workspace resolution, preflight, image build, GitHub setup, or container launch.
if [ "${1:-}" = "learn" ]; then
  learning_handle_subcommand "$@"
  # learning_handle_subcommand always exits; this is a safety net.
  exit $?
fi

# ── Repos subcommand dispatch (task_017) ──────────────────────────────────────
# Must be BEFORE the --* flag-parser loop — exactly like the `learn` block
# above — otherwise `vibe repos add owner/repo` falls through to
# parse_vibe_args's positional catch-all and gets treated as a project name.
# Dispatches and exits; does NOT enter workspace resolution, preflight, image
# build, GitHub setup, or container launch.
if [ "${1:-}" = "repos" ]; then
  repos_handle_subcommand "$@"
  # repos_handle_subcommand's sub-functions always exit; this is a safety net.
  exit $?
fi

# ── Flags ─────────────────────────────────────────────────────────────────────
# parse_vibe_args (defined above the VIBE_SOURCE_ONLY guard so smoke-test.py
# can source-test it) accepts flags and the project positional in any order.
parse_vibe_args "$@"

if [ "$CONTINUE" = true ] && [ "$RESUME" = true ]; then
  echo "  ✗ --continue and --resume are mutually exclusive."
  exit 1
fi

# ── Model selection: config default + Fable billing gate ─────────────────────
# Flags win over the VIBE_MODEL config default. An invalid VIBE_MODEL is
# ignored with a warning rather than blocking the launch.
if [ -z "$MODEL_ARG" ] && [ -n "${VIBE_MODEL:-}" ]; then
  if is_model_id "$VIBE_MODEL"; then
    MODEL_ARG="$VIBE_MODEL"
  else
    echo "  ⚠ Ignoring invalid VIBE_MODEL in config: '$VIBE_MODEL'" >&2
  fi
fi

# Fable 5 left Pro/Max subscription cover on 8 Jul 2026 (usage credits at API
# list rates from then on). vibe's default posture is subscription-only spend,
# so from the cutover the launch needs a per-run confirm or a standing opt-in
# (VIBE_FABLE_CREDITS_OK=1 in ~/.vibe/config). Before the cutover it's free.
if [ "$MODEL_ARG" = "$FABLE_MODEL_ID" ]; then
  if [ "$(fable_billing_phase)" = "free" ]; then
    echo "  ◆ Fable 5: included in your Pro/Max subscription at no extra cost until 7 Jul 2026."
  elif [ "${VIBE_FABLE_CREDITS_OK:-}" = "1" ]; then
    echo "  ◆ Fable 5: billing usage credits at API rates (VIBE_FABLE_CREDITS_OK=1)."
  else
    echo "  ⚠ Fable 5 is no longer included in Pro/Max subscriptions (since 8 Jul 2026)."
    echo "    Sessions bill usage credits at API list rates (\$10/MTok in, \$50/MTok out)"
    echo "    ON TOP of your subscription. vibe's default is subscription-only spend."
    if ask_yes_no "Launch with Fable 5 anyway?" n; then
      echo "  ◆ Launching on Fable 5 (usage credits). Set VIBE_FABLE_CREDITS_OK=1 in ~/.vibe/config to skip this ask."
    else
      MODEL_ARG=""
      echo "  ◆ Launching on your default model instead."
    fi
  fi
fi

# ── Resolve workspace ─────────────────────────────────────────────────────────
if [ -z "$PROJECT_ARG" ]; then
  # pwd -P (not plain pwd): getcwd() returns the kernel's canonical on-disk
  # path, fixing case (e.g. /users vs /Users on case-insensitive-but-preserving
  # APFS) and symlinks. Docker bind-mount source validation is case-sensitive,
  # so a logically-lowercased $PWD would fail with "bind source path does not
  # exist" on every run, including --rebuild.
  WORKSPACE="$(pwd -P)"
  PROJECT_NAME="$(basename "$WORKSPACE")"
else
  PROJECT_NAME="$PROJECT_ARG"
  if [ -d "$PROJECT_NAME" ]; then
    WORKSPACE="$(cd "$PROJECT_NAME" && pwd -P)"
    PROJECT_NAME="$(basename "$WORKSPACE")"
  else
    WORKSPACE="$PROJECTS_DIR/$PROJECT_NAME"
    if [ ! -d "$WORKSPACE" ]; then
      echo "  Error: Project not found: $WORKSPACE"
      echo ""
      echo "  Available projects:"
      ls "$PROJECTS_DIR"
      exit 1
    fi
  fi
fi

# ── task_017 Cycle 3 (AC13) integrator note ──────────────────────────────────
# VIBE_PROJECT_NAME identifies THIS session for shared-repo rw-lock/claim
# resolution. Exported here (remoteEnv only, mirroring the GITHUB_TOKEN export
# further down — never containerEnv) so ${localEnv:VIBE_PROJECT_NAME} in
# devcontainer.json's remoteEnv resolves; the in-container statusLine compares
# it against a shared-repo lock's `project=` field to decide whether THIS
# session is the rw-holder before appending the `⚠ rw:<requester>` segment.
# This export is independent of Cycle 1/2's registry/mount/lock plumbing —
# it only needs PROJECT_NAME, already resolved above.
VIBE_PROJECT_NAME="$PROJECT_NAME"
export VIBE_PROJECT_NAME

# ── Preflight ─────────────────────────────────────────────────────────────────
require docker       "Install OrbStack (https://orbstack.dev) or Docker Desktop."
require devcontainer "Install with: npm install -g @devcontainers/cli"
require gh           "Install from: https://cli.github.com"

# Suppress Docker Desktop's "What's next? Try Docker Debug..." hint.
# DOCKER_CLI_HINTS=false is the documented mechanism but doesn't always
# propagate through the devcontainer CLI to its docker subprocesses, so we
# also persist the setting in ~/.docker/config.json.
export DOCKER_CLI_HINTS=false
ensure_docker_hints_off

if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
  echo "  ⚠  ANTHROPIC_API_KEY is set — Claude Code inside the container would bill"
  echo "     against API credits if it honoured it. vibe forces subscription auth via"
  echo "     settings.local.json (forceLoginMethod=claudeai), so this should be"
  echo "     ignored — but unset it in your host env for good measure."
  echo ""
fi

if [ ! -f "$DEVCONTAINER_DIR/devcontainer.json" ]; then
  echo "  ✗ vibe source not found at $DEVCONTAINER_DIR"
  echo "    Run the installer:"
  echo "      bash <(curl -fsSL https://raw.githubusercontent.com/Aqueum/vibe/main/install.sh)"
  exit 1
fi

# devcontainer.json bind-mounts ~/.ssh and ~/.gitconfig into the container.
# On a fresh Mac neither may exist yet, which makes the bind mount fail hard.
# Create them eagerly with the permissions SSH tools would set anyway.
if [ ! -d "$HOME/.ssh" ]; then
  mkdir -p "$HOME/.ssh"
  chmod 700 "$HOME/.ssh"
fi
[ -f "$HOME/.gitconfig" ] || touch "$HOME/.gitconfig"

# ── GitHub setup ──────────────────────────────────────────────────────────────
GITHUB_TOKEN=""
GITHUB_REPO=""
cd "$WORKSPACE"

if is_github_skipped; then
  : # silently skip — user said never
elif GITHUB_REPO=$(detect_github_repo); then
  GITHUB_TOKEN=$(lookup_token "$GITHUB_REPO")
  if [ -z "$GITHUB_TOKEN" ]; then
    setup_token "$GITHUB_REPO"
  fi
else
  create_github_repo
  if [ -n "$GITHUB_REPO" ]; then
    setup_token "$GITHUB_REPO"
  fi
fi

# ── Build the image if missing, stale, or --rebuild ──────────────────────────
# Auto-rebuild when any file in $DEVCONTAINER_DIR is newer than $IMAGE_MARKER
# (touched after each successful build). Catches updated Dockerfile, firewall
# script, etc. after `install.sh` or manual edits without needing --rebuild.
if [ "$REBUILD" != true ] && docker image inspect "$IMAGE_TAG" >/dev/null 2>&1; then
  if [ ! -f "$IMAGE_MARKER" ] \
     || [ -n "$(find "$DEVCONTAINER_DIR" -type f -newer "$IMAGE_MARKER" -print 2>/dev/null | head -n 1)" ]; then
    echo "  devcontainer/ changed since last build — rebuilding image."
    REBUILD=true
  fi
fi

if [ "$REBUILD" = true ] || ! docker image inspect "$IMAGE_TAG" >/dev/null 2>&1; then
  # Resolve current Claude Code "latest" host-side. Without this the
  # Dockerfile RUN string `npm install ...@latest` is byte-identical
  # between rebuilds, so Docker reuses the cached layer even when the
  # npm `latest` tag has moved on. Passing the resolved version as a
  # build-arg makes the layer cache key version-sensitive. Falls back
  # to "latest" if npm isn't on the host (Dockerfile ARG default).
  CLAUDE_CC_VERSION="latest"
  if command -v npm >/dev/null 2>&1; then
    CLAUDE_CC_VERSION="$(npm view @anthropic-ai/claude-code version 2>/dev/null || echo latest)"
  fi
  echo "  Building vibe container image ($IMAGE_TAG, claude-code=${CLAUDE_CC_VERSION})..."
  docker build --build-arg "CLAUDE_CODE_VERSION=${CLAUDE_CC_VERSION}" -t "$IMAGE_TAG" "$DEVCONTAINER_DIR"
  mkdir -p "$(dirname "$IMAGE_MARKER")"
  touch "$IMAGE_MARKER"
fi

# ── Write persistent session settings ────────────────────────────────────────
# settings.local.json is read by Claude Code at startup. Written fresh on every
# launch so these settings are always in effect regardless of how the project
# was cloned or whether the file existed before.
#
#   permissions.defaultMode bypassPermissions — YOLO mode (no approval prompts)
#   forceLoginMethod claudeai                 — use Claude Pro/Max subscription,
#                                               not an API key
#   hooks                                     — tool-call backstop: PreToolUse
#                                               blocks history-overwriting
#                                               force-push; Stop/Notification
#                                               ring the terminal bell so the
#                                               outer terminal tab badges when
#                                               Claude goes idle or needs
#                                               input; PreToolUse/PostToolUse/
#                                               Stop also refresh
#                                               .vss/heartbeat while a /vsss
#                                               --sessions marker is active,
#                                               feeding the launcher's stall
#                                               watchdog (see the auto-resume
#                                               comment block above)
#   statusLine                                  — one-glance session state at
#                                               the bottom of the TUI: model
#                                               as a single letter (F/O/S/H,
#                                               full display name for anything
#                                               unrecognised), a "vibe" cue to
#                                               tell vibe windows from plain
#                                               claude ones, then context-used
#                                               and 5h-window percentages when
#                                               Claude Code supplies them
#                                               (absent before the first API
#                                               response — segments simply
#                                               drop out); task_017 Cycle 3
#                                               (AC13) adds a trailing
#                                               " · ⚠ rw:<requesting-project>"
#                                               segment when THIS session
#                                               holds a shared repo's rw
#                                               lock (VIBE_PROJECT_NAME
#                                               matches the lock meta's
#                                               project=) AND that repo has
#                                               a pending rw-request under
#                                               ${VIBE_REPOS_DIR:-/repos}/
#                                               .signals/<name>/ — absent
#                                               entirely when no shared
#                                               repos/signals exist, so the
#                                               pre-existing exact-output
#                                               fixtures are untouched. The
#                                               bell (best-effort per the
#                                               AC) goes to stderr, not
#                                               stdout, so it never affects
#                                               the exact-match stdout
#                                               fixtures either way
mkdir -p "$WORKSPACE/.claude"
cat > "$WORKSPACE/.claude/settings.local.json" << 'EOF'
{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "forceLoginMethod": "claudeai",
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); m=$(printf '%s' \"$input\" | jq -r '.model.display_name // \"?\"'); case \"$m\" in *Fable*) l=F;; *Opus*) l=O;; *Sonnet*) l=S;; *Haiku*) l=H;; *) l=\"$m\";; esac; ctx=$(printf '%s' \"$input\" | jq -r '.context_window.used_percentage // \"\" | if type==\"number\" then (floor|tostring) else . end'); win=$(printf '%s' \"$input\" | jq -r '.rate_limits.five_hour.used_percentage // \"\" | if type==\"number\" then (floor|tostring) else . end'); out=\"$l · vibe\"; [ -n \"$ctx\" ] && out=\"$out · ctx ${ctx}%\"; [ -n \"$win\" ] && out=\"$out · 5h ${win}%\"; sig_root=\"${VIBE_REPOS_DIR:-/repos}/.signals\"; rwseg=\"\"; if [ -d \"$sig_root\" ]; then for d in \"$sig_root\"/*/; do [ -d \"$d\" ] || continue; meta=\"$d/rw-lock.d/meta\"; req=\"$d/rw-request\"; if [ -f \"$meta\" ] && [ -f \"$req\" ]; then holder=$(grep '^project=' \"$meta\" 2>/dev/null | head -n1 | cut -d= -f2-); if [ -n \"$holder\" ] && [ \"$holder\" = \"${VIBE_PROJECT_NAME:-}\" ]; then requester=$(grep '^project=' \"$req\" 2>/dev/null | head -n1 | cut -d= -f2-); if [ -n \"$requester\" ]; then rwseg=\" · ⚠ rw:${requester}\"; printf '\\a' >&2; break; fi; fi; fi; done; fi; out=\"${out}${rwseg}\"; printf '%s' \"$out\""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "/usr/local/bin/guard-bash.sh" }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "/usr/local/bin/guard-fs.sh" }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "[ -f /workspace/.vss/auto-resume ] && { date +%s > /workspace/.vss/heartbeat.tmp.$$ && mv /workspace/.vss/heartbeat.tmp.$$ /workspace/.vss/heartbeat; } || true" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "[ -f /workspace/.vss/auto-resume ] && { date +%s > /workspace/.vss/heartbeat.tmp.$$ && mv /workspace/.vss/heartbeat.tmp.$$ /workspace/.vss/heartbeat; } || true" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "printf '\\a' >&2" },
          { "type": "command", "command": "[ -f /workspace/.vss/auto-resume ] && { date +%s > /workspace/.vss/heartbeat.tmp.$$ && mv /workspace/.vss/heartbeat.tmp.$$ /workspace/.vss/heartbeat; } || true" }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "printf '\\a' >&2" }
        ]
      }
    ]
  }
}
EOF

# Keep settings.local.json out of git (it's personal/session config).
if [ -f "$WORKSPACE/.gitignore" ]; then
  if ! grep -qF ".claude/settings.local.json" "$WORKSPACE/.gitignore"; then
    echo ".claude/settings.local.json" >> "$WORKSPACE/.gitignore"
  fi
fi

# ── Launch via devcontainer CLI ──────────────────────────────────────────────
# export so ${localEnv:GITHUB_TOKEN} in devcontainer.json resolves in this env.
export GITHUB_TOKEN

# ── Per-repo credential env (task_017 shared-repos, AC18) ────────────────────
# The in-container credential helper (devcontainer/credential-helper.sh) routes
# a DIFFERENT single-repo PAT per requested repo path. It needs two things in
# the container env:
#   • GITHUB_REPO_SLUG — the project's OWN owner/repo. An exact path match here
#     is the ONLY case that serves $GITHUB_TOKEN (the never-widen anchor).
#     Carried statically in devcontainer.json's remoteEnv so it ALWAYS reaches
#     the container, even for single-repo projects that generate no override
#     config — without it, useHttpPath would break `git push` to the project's
#     own repo. Just a slug, not a secret, but kept in remoteEnv beside the
#     token for consistency (never containerEnv / firewall / postStart layer).
#   • VIBE_SHARED_TOKEN_<SANITISED> — one scoped PAT per DECLARED shared repo.
# These MUST be exported at TOP-LEVEL scope, NEVER inside _build_override_config:
# that function runs via command substitution ($(...)), and exports made in a
# subshell die with it — the exact trap documented for learning_load at
# vibe:1691-1696. Export here so the ${localEnv:...} passthroughs resolve.
export GITHUB_REPO_SLUG="$GITHUB_REPO"

# Enumerate the project's declared shared repos (C1's shared_repos_parse, AC2)
# and export each one's scoped token. Guarded: this cycle (C4) integrates on top
# of C1-C3, so if the parser isn't present in this tree the loop is simply
# skipped (no shared tokens -> the helper's single-repo compat path still works).
# VIBE_SHARED_ENV_NAMES collects the exported names so render_devcontainer_with_
# mounts can add matching remoteEnv passthroughs. A missing token is a WARNING,
# not a mount-blocker (AC18): the var is still exported (empty) so the helper
# fails CLOSED for that repo rather than falling back to $GITHUB_TOKEN.
VIBE_SHARED_ENV_NAMES=""
if declare -F shared_repos_parse >/dev/null 2>&1 && [ -f "$WORKSPACE/.vibe-repos" ]; then
  while read -r _slug _mode; do
    [ -z "$_slug" ] && continue
    _env_name=$(shared_repo_env_name "$_slug")
    _shared_tok=$(lookup_token "$_slug")
    if [ -z "$_shared_tok" ]; then
      echo "  ⚠ vibe: shared repo $_slug has no PAT staged — read-only local reads still" >&2
      echo "    work, but fetch/push to it will fail (fix: vibe repos add $_slug)." >&2
    fi
    export "$_env_name"="$_shared_tok"
    # Twin export: the EXACT declared slug under VIBE_SHARED_SLUG_<SANITISED>.
    # The helper re-verifies a routed request against this before serving —
    # sanitisation is lossy (foo-bar/baz vs foo/bar-baz), and env-name match
    # alone must never be treated as slug identity (security-review C4).
    export "VIBE_SHARED_SLUG_${_env_name#VIBE_SHARED_TOKEN_}"="$_slug"
    case " $VIBE_SHARED_ENV_NAMES " in
      *" $_env_name "*) : ;;                       # de-dupe (collision guarded at add-time)
      *) VIBE_SHARED_ENV_NAMES="${VIBE_SHARED_ENV_NAMES}${VIBE_SHARED_ENV_NAMES:+ }$_env_name" ;;
    esac
  done < <(shared_repos_parse "$WORKSPACE/.vibe-repos")
fi
export VIBE_SHARED_ENV_NAMES

# Zotero web-API key (optional). Stored alongside the GitHub PATs in
# ~/.vibe/tokens (chmod 600) under the reserved, slash-free key
# `ZOTERO_API_KEY` — it can't collide with an `owner/repo` PAT entry. Exported
# so ${localEnv:ZOTERO_API_KEY} resolves; passed via remoteEnv only (never
# containerEnv), mirroring GITHUB_TOKEN so the secret never reaches the
# firewall/postStart layer. Empty when unset — harmless.
ZOTERO_API_KEY=$(lookup_token "ZOTERO_API_KEY")
export ZOTERO_API_KEY

# OpenProject MCP (optional). The self-hosted OP MCP is deployed as a
# tailnet-only HTTPS sidecar; its endpoint URL + bearer are staged in
# ~/.vibe/tokens (chmod 600) under the reserved, slash-free keys
# `OPENPROJECT_MCP_URL` / `OPENPROJECT_MCP_BEARER`. Exported so the matching
# ${localEnv:...} resolve; passed via remoteEnv only, mirroring GITHUB_TOKEN so
# the bearer never reaches the firewall/postStart layer. Empty when unset.
# The container is not on the tailnet, so reaching the tailnet-only sidecar is
# bridged by a Mac-side forwarder (_ensure_op_forwarder, below) plus an
# in-container registration (register-op-mcp.sh). OPENPROJECT_MCP_FWD_PORT is the
# loopback port both sides agree on. Staging creds with no live sidecar is
# harmless — the in-container registration is reachability-gated.
OPENPROJECT_MCP_URL=$(lookup_token "OPENPROJECT_MCP_URL")
OPENPROJECT_MCP_BEARER=$(lookup_token "OPENPROJECT_MCP_BEARER")
OPENPROJECT_MCP_FWD_PORT="$OP_MCP_FWD_PORT"
export OPENPROJECT_MCP_URL OPENPROJECT_MCP_BEARER OPENPROJECT_MCP_FWD_PORT
_ensure_op_forwarder

# Load learning config into THIS shell before the subshell below, so the
# banner check at the end of this block sees the same state that
# _build_override_config sees. (Exports from inside $(...) die with the
# subshell, so without this the banner never prints even when /learnings
# is mounted.)
learning_load

# ── Shared-repo rw intents (task_017 C2) ── must run in THIS shell, before
# _build_override_config: lock acquisition is a side effect and the release
# hooks register into VIBE_EXIT_HOOKS — both would die inside the $(...)
# below (the exact subshell trap the learning_load comment above documents).
# Mount assembly then re-resolves each repo's mode idempotently via
# shared_repo_resolve_mode (acquire is re-entrant on project+pid, and $$
# inside the subshell is this shell's pid). Contention warnings are queued
# in VIBE_SHARED_REPO_WARNINGS and printed inside the banner block below.
shared_repos_apply_rw_intents "$WORKSPACE/.vibe-repos" "$PROJECT_NAME" "$$"

# Resolve the override config: a generated per-session JSON with the learning /
# brain / zotero mounts injected if any apply, else the source config.
OVERRIDE_CONFIG=$(_build_override_config "$WORKSPACE")

# Shared repos (task_017 cycle 1): one scan feeds BOTH the runtime manifest
# (AC5) and the header lines below, so the two can never disagree about
# what's mounted. _build_override_config already ran its own internal scan
# to build the bind-mount triples; shared_repos_scan is guarded/idempotent,
# so re-running it here (in this shell, not a subshell, so the result can be
# reused twice below) is safe — just mildly redundant filesystem work (a
# git-checkout existence test + an idempotent mkdir per repo).
SHARED_REPOS_SCAN="$(shared_repos_scan "$WORKSPACE")"

# Runtime manifest (AC5): written STRICTLY BEFORE `devcontainer up` so
# postStart's install-claude-extras.sh sees it in the SAME launch — this
# ordering is load-bearing for the relaunch right after `vibe repos add`,
# which needs the NEW repo's safe.directory entry on that very next launch,
# not the one after. Truncates to empty (via the unconditional `>`) when
# there are no mounted shared repos, rather than leaving the file absent.
SHARED_REPOS_MANIFEST="$WORKSPACE/.vibe/shared-repos.manifest"
mkdir -p "$(dirname "$SHARED_REPOS_MANIFEST")"
shared_repos_manifest_lines "$SHARED_REPOS_SCAN" > "$SHARED_REPOS_MANIFEST"

echo ""
if [ "$CONTINUE" = true ]; then
  echo "  ↻ vibe session continuing (most recent Claude conversation)"
elif [ "$RESUME" = true ] && [ -n "$RESUME_UID" ]; then
  echo "  ↻ vibe session resuming (Claude session ${RESUME_UID:0:8}…)"
elif [ "$RESUME" = true ]; then
  echo "  ↻ vibe session resuming (Claude conversation picker)"
else
  echo "  🚀 vibe session starting"
fi
echo "     project : $PROJECT_NAME"
echo "     path    : $WORKSPACE"
[ -n "$GITHUB_REPO" ] && echo "     github  : $GITHUB_REPO"
echo "     hooks   : tool-call guards + idle bell"
echo "     extras  : /diet · /feast · /vs · shellcheck-fixer · security-review"
# Learning banner: three states. Silent when never inited / globally off.
# "excluded" confirms a project-level .no-learn to reassure the user the
# opt-out took effect. Otherwise show visibility + library path.
case "$(learning_banner_state "$WORKSPACE")" in
  enabled)
    echo "     learn   : ${VIBE_LEARNING_VISIBILITY:-private} @ ${VIBE_LEARNING_PATH}"
    ;;
  excluded)
    echo "     learn   : excluded"
    ;;
esac
# Brain / Zotero mount banners — mirror the gating in _build_override_config so
# the line only prints when the mount is actually injected.
_brain2_banner="$(_brain2_source)"
if [ -n "$_brain2_banner" ] && [ -d "$_brain2_banner" ]; then
  _canon_ws="$(cd "$WORKSPACE" 2>/dev/null && pwd -P || echo "$WORKSPACE")"
  _canon_brain2="$(cd "$_brain2_banner" 2>/dev/null && pwd -P || echo "$_brain2_banner")"
  if [ "$_canon_ws" = "$_canon_brain2" ]; then
    echo "     brain2  : this workspace (gardener) @ ${_brain2_banner}"
  else
    echo "     brain2  : /brain2 (rw) @ ${_brain2_banner}"
  fi
fi
_zotero_banner="$(_zotero_source)"
if [ -n "$_zotero_banner" ] && [ -d "$_zotero_banner" ]; then
  echo "     zotero  : /zotero (ro) @ ${_zotero_banner}"
fi
# Shared-repos header (AC4): driven entirely by SHARED_REPOS_SCAN's M/B/N/U
# tags (see shared_repos_scan's comment) — one ◆ line per MOUNTED repo, one
# loud ⚠ warning per registered-but-broken repo naming the reason, and
# NOTHING for a never-registered declaration (the `N)` arm below is a
# deliberate no-op, not an omission — that's the community-contributor
# silence AC4 asks for, and the explicit branch is what lets a test assert
# the code path distinguishes "no registry entry" from "registry entry
# broken" rather than inferring it from absence of output).
if [ -n "$SHARED_REPOS_SCAN" ]; then
  while IFS= read -r _shared_line; do
    case "$_shared_line" in
      M\ *)
        read -r _shared_name _shared_mode _shared_slug _shared_path <<< "${_shared_line#M }"
        echo "  ◆ shared repo: $_shared_slug at /repos/$_shared_name ($_shared_mode)"
        ;;
      B\ *)
        read -r _shared_slug _shared_reason <<< "${_shared_line#B }"
        echo "  ⚠ shared repo $_shared_slug BROKEN: $_shared_reason"
        ;;
      N\ *) ;;  # never registered on this machine — deliberate silence
      U\ *)
        read -r _shared_slug <<< "${_shared_line#U }"
        echo "  ⚠ shared repo $_shared_slug declared but not authorised for this project — mount skipped; run 'vibe repos add $_shared_slug' here to authorise"
        ;;
    esac
  done <<< "$SHARED_REPOS_SCAN"
fi
# Shared-repo rw contention fallbacks (queued by shared_repos_apply_rw_intents
# above): loud, names the holder project + since-time. Successful rw grants
# need no extra line here — the per-repo "◆ shared repo:" header line (C1)
# reports the effective mode, which resolve_mode already flipped.
if [ "${#VIBE_SHARED_REPO_WARNINGS[@]}" -gt 0 ]; then
  for _srw_line in "${VIBE_SHARED_REPO_WARNINGS[@]}"; do
    echo "$_srw_line"
  done
fi
echo ""

UP_BASE_ARGS=(
  up
  --workspace-folder "$WORKSPACE"
  --override-config "$OVERRIDE_CONFIG"
)
UP_ARGS=("${UP_BASE_ARGS[@]}")
# Detect image drift (container built from a superseded image) and fold in the
# --rebuild flag so the flag is appended exactly once via remove_existing_flag.
drift_marker="$(image_drift_needs_recreate "$WORKSPACE" "$IMAGE_TAG")"
extra_flag="$(remove_existing_flag "$REBUILD" "$drift_marker")"
[ -n "$extra_flag" ] && UP_ARGS+=("$extra_flag")
# Print a distinct status line when drift (not --rebuild) triggered the recreate.
if [ -n "$drift_marker" ] && [ "$REBUILD" != true ]; then
  echo "  image moved on since this project's container was built - recreating it."
  echo ""
fi

# If `devcontainer up` fails, the postStartCommand likely died mid-way (e.g.
# init-firewall.sh bombed out), leaving a container that's running but only
# partially configured — dangerous, because the next `vibe` invocation would
# skip postStart entirely and silently use a half-locked-down firewall.
# Retry once with --remove-existing-container to get a clean state. If that
# still fails, surface the error rather than hide it.
if ! devcontainer "${UP_ARGS[@]}"; then
  echo ""
  echo "  ⚠  postStartCommand failed — container is in a partial state."
  echo "     Removing it and retrying once with a fresh container."
  echo ""
  if ! devcontainer "${UP_BASE_ARGS[@]}" --remove-existing-container; then
    echo ""
    echo "  ✗ Retry also failed. Fix the underlying error above and re-run."
    echo "    If the image itself is suspect: vibe --rebuild"
    exit 1
  fi
fi

# Start claude with a clean, deterministic shell env:
#   - `bash --noprofile --norc` — launcher shell sources no rc files
#   - `env SHELL=/bin/bash` — Claude Code's env-snapshot subprocess spawns
#     non-interactive bash (reads no rc), not the image's default zsh
#   - `LC_ALL=C.UTF-8 LANG=C.UTF-8` — silences the bash "locale not supported"
#     warning when the host inherits en_US.UTF-8 (and neutralises any older
#     image whose zsh-in-docker .zshrc re-exports it before the Dockerfile sed)
#
# Note: two issues recommend switching away from Apple's Terminal.app
# (and similar stock/restricted terminals):
# (1) a stray "p" sometimes seen before the banner is NOT a shell-rc leak —
#     it's Terminal.app's VT parser mishandling claude's `\e[?2026$p` DECRQM
#     (synchronized-output) probe and echoing the `p` terminator.
# (2) Terminal.app lacks OSC 52 clipboard support, so exact-byte copy from
#     inside the container to the Mac clipboard isn't possible without
#     file-mount workarounds. Any future `vibe-copy` / `/copy` feature
#     requires OSC 52 on the outer terminal.
# Recommended replacement: Ghostty (MIT, cross-platform, Zig+Swift, native
# Mac polish, OSC 52 out of the box). Alternatives that also work:
# iTerm2 / Kitty / Alacritty / WezTerm.
# `exec` replaces bash with claude so signals go straight to claude.
# build_claude_resume_args echoes "" / "--continue" / "--resume" / "--resume <uuid>".
# RESUME_UID is restricted to UUID format by is_uuid in the parser, so embedding
# it in the command string is injection-safe.
WATCHER_PID=""
if [[ "$(uname)" == "Darwin" ]] && command -v pbcopy >/dev/null 2>&1; then
  mkdir -p "$WORKSPACE/.vibe"
  CLIP="$WORKSPACE/.vibe/copy-latest.txt"
  # shellcheck disable=SC2034  # read at exit time inside the hook string
  # registered below (shellcheck can parse trap strings but not hook strings).
  WATCHER_SEED_MTIME=$(stat -f %m "$CLIP" 2>/dev/null || stat -c %Y "$CLIP" 2>/dev/null || echo 0)
  pkill -f "vibe-copy-watcher\.sh ${WORKSPACE}\$" 2>/dev/null || true
  "$VIBE_REPO_DIR/vibe-copy-watcher.sh" "$WORKSPACE" &
  # shellcheck disable=SC2034  # same: consumed by the exit hook string below
  WATCHER_PID=$!
  # Clipboard flush + watcher reap on exit. The hook BODY is byte-identical
  # to the pre-dispatcher `trap ... EXIT` registration (task_008/016 smoke
  # checks and MANUAL-TESTS pin its behaviour); only the registration
  # mechanism changed — it now shares the single EXIT slot with the
  # shared-repo lock release via vibe_on_exit (see the dispatcher block).
  vibe_exit_hook_add 'if [ -s "$CLIP" ] && [ "$(stat -f %m "$CLIP" 2>/dev/null || stat -c %Y "$CLIP" 2>/dev/null || echo 0)" != "$WATCHER_SEED_MTIME" ]; then pbcopy < "$CLIP" 2>/dev/null || true; fi; kill "$WATCHER_PID" 2>/dev/null || true'
fi

# build_claude_model_args echoes "" / "--model <id>". MODEL_ARG is restricted
# to [A-Za-z0-9._-] by is_model_id, so embedding it is injection-safe.
CLAUDE_RESUME_ARGS=$(build_claude_resume_args)
CLAUDE_MODEL_ARGS=$(build_claude_model_args)

# launch_claude <resume-args> <initial-prompt>
#   $1 — "" / "--continue" / "--resume" / "--resume <uuid>" (parser-validated)
#   $2 — optional initial prompt. Only ever a FIXED LITERAL from this script
#        (currently "/vsss --resume") — never user input — so single-quoting
#        it into the container command string is injection-safe.
#   Body is `exec devcontainer exec ...`: launch_claude is only ever invoked
#   backgrounded (from launch_claude_supervised below), so the subshell it
#   runs in replaces itself with the devcontainer-exec client process, and
#   `$!` at the call site is that client's real PID — required for the
#   stall watchdog's `kill -0`/kill-fallback to target the right process.
launch_claude() {
  exec devcontainer exec \
    --workspace-folder "$WORKSPACE" \
    --override-config "$OVERRIDE_CONFIG" \
    /bin/bash --noprofile --norc -c "exec env SHELL=/bin/bash LC_ALL=C.UTF-8 LANG=C.UTF-8 claude ${1:+$1 }${CLAUDE_MODEL_ARGS:+$CLAUDE_MODEL_ARGS }--permission-mode bypassPermissions${2:+ '$2'}"
}

# VIBE_SESSION_REF — a session-start reference file, used solely for its
# mtime: the stall watchdog only arms its kill for a marker that was
# (re)written AFTER this launcher session began (portable `[ marker -nt ref ]`
# — no stat -c/-f). That's what stops a crash-left marker from an earlier
# --sessions run arming a kill against an unrelated interactive session
# started later in the same project. On mktemp failure the variable stays
# EMPTY, and the empty-ref case never arms (fail-safe toward not killing).
VIBE_SESSION_REF=$(mktemp "${TMPDIR:-/tmp}/vibe-session-ref.XXXXXX" 2>/dev/null) || VIBE_SESSION_REF=""

# AUTO_RESUME_MARKER / AUTO_RESUME_HEARTBEAT — paths the whole auto-resume +
# stall-watchdog machinery reads/writes, defined once before the first
# supervised launch.
AUTO_RESUME_MARKER="$WORKSPACE/.vss/auto-resume"
AUTO_RESUME_HEARTBEAT="$WORKSPACE/.vss/heartbeat"

# CLAUDE_EXIT — global, holds the exit status of the most recent claude run.
# Set by launch_claude_supervised; the launcher's final statement propagates
# it as vibe's own exit code (see the bottom of this script).
CLAUDE_EXIT=0

# launch_claude_supervised <resume-args> <initial-prompt> <ref-file>
#   Seeds the heartbeat (if a marker exists), backgrounds launch_claude,
#   captures its PID, runs vibe_stall_watchdog alongside it, waits for
#   claude, stores its exit status in CLAUDE_EXIT, then reaps the watchdog.
#   Every intermediate command that can fail is individually guarded — this
#   function must be un-trippable under `set -e` and always return 0.
#   $3 (ref-file): "" (e.g. VIBE_SESSION_REF after a mktemp failure) never
#   arms the watchdog's kill; the literal sentinel "-" (relaunch call sites)
#   always arms (a freshly relaunched window may already be stalled at the
#   picker before the skill can refresh the marker); anything else is a real
#   ref-file path gated by vibe_stall_watchdog's marker-mtime check.
launch_claude_supervised() {
  local resume_args="$1" prompt="$2" ref="$3" claude_pid wd_pid rc=0
  if [ -f "$AUTO_RESUME_MARKER" ]; then
    auto_resume_heartbeat_write "$AUTO_RESUME_HEARTBEAT" || true
  fi
  # HOTFIX 2026-07-11 (first live launch after task_016 shipped): POSIX gives
  # an async (&) command /dev/null as stdin when job control is off — so the
  # backgrounded claude saw a non-TTY stdin, assumed print mode, and died
  # with "Input must be provided either through stdin or as a prompt
  # argument when using --print" on every fresh vibe launch. Explicitly
  # re-attach the launcher's own stdin via a dup'd FD (an explicit
  # redirection overrides the /dev/null default); FD 9 is opened once below,
  # before the first supervised launch. Exactly the class of bug the smoke
  # suite cannot see and MANUAL-TESTS Test 32 exists for.
  launch_claude "$resume_args" "$prompt" <&9 &
  claude_pid=$!
  vibe_stall_watchdog "$claude_pid" "$AUTO_RESUME_MARKER" "$AUTO_RESUME_HEARTBEAT" "$ref" &
  wd_pid=$!
  wait "$claude_pid" || rc=$?
  CLAUDE_EXIT="$rc"
  kill "$wd_pid" 2>/dev/null || true
  wait "$wd_pid" 2>/dev/null || true
  return 0
}

# FD 9 = the launcher's real stdin (the terminal), duplicated once so every
# supervised launch can hand it to the backgrounded claude explicitly (see
# the HOTFIX note inside launch_claude_supervised). Guarded: nothing to dup
# is fatal only if stdin is already closed, which a launcher run never has.
exec 9<&0

launch_claude_supervised "$CLAUDE_RESUME_ARGS" "" "$VIBE_SESSION_REF"

# ── Auto-resume loop ──────────────────────────────────────────────────────────
# Engages only when /vsss --sessions X left an active marker (see the
# auto_resume_* helpers above). Waits out the 5h-window reset, then relaunches
# the conversation with a literal "/vsss --resume" prompt. Ctrl-C during the
# countdown cancels; deleting .vss/auto-resume deactivates permanently.
while auto_resume_pending "$AUTO_RESUME_MARKER"; do
  _ar_remaining=$(auto_resume_field "$AUTO_RESUME_MARKER" remaining)
  _ar_resume_at=$(auto_resume_field "$AUTO_RESUME_MARKER" resume_at)
  _ar_now=$(date +%s)
  # No usable reset estimate → 30 min default; estimate already past → 2 min
  # grace. Both bound a tight relaunch loop if the window hasn't really reset.
  _ar_wait=1800
  if [ -n "$_ar_resume_at" ]; then
    if [ "$_ar_resume_at" -gt "$_ar_now" ]; then
      _ar_wait=$(( _ar_resume_at - _ar_now + 120 ))
    else
      _ar_wait=120
    fi
  fi
  echo ""
  echo "  ◆ auto-resume: /vsss marker active, ${_ar_remaining} relaunch(es) left."
  echo "    Relaunching claude --continue in $(( _ar_wait / 60 ))m $(( _ar_wait % 60 ))s — Ctrl-C to cancel, or delete .vss/auto-resume."
  # Re-armed at the top of EVERY iteration, immediately before the countdown
  # sleep; reset right after. Registers ONLY the INT slot — must never touch
  # the EXIT slot, so vibe_on_exit (clipboard flush + lock release) still
  # fires on this exit-130 path. Cancel means cancel: deactivate the marker
  # so a stale "active=1" doesn't linger, but crash paths (no trap fires)
  # deliberately leave the marker alone so a crash-left marker still resumes.
  trap 'auto_resume_deactivate "$AUTO_RESUME_MARKER"; echo ""; echo "  ◆ auto-resume: cancelled (Ctrl-C) — marker deactivated."; exit 130' INT
  sleep "$_ar_wait"
  trap - INT
  auto_resume_decrement "$AUTO_RESUME_MARKER"
  launch_claude_supervised "--continue" "/vsss --resume" "-"
done

# Propagate the last claude run's exit status as vibe's own — the old
# `|| true` swallow is gone, superseded by launch_claude_supervised capturing
# CLAUDE_EXIT past `set -e`.
exit "$CLAUDE_EXIT"
