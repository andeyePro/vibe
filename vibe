#!/bin/bash
# vibe — single-command containerised YOLO Claude Code sessions
# https://github.com/Aqueum/vibe
#
# Usage:
#   vibe                  # cd to your project folder, then just run this
#   vibe <project-name>   # launch by name from anywhere (uses VIBE_PROJECTS_DIR)
#   vibe --rebuild        # force rebuild of the vibe container image
#   vibe --continue       # resume the most recent Claude conversation in this dir
#   vibe --resume         # interactively pick a Claude conversation to resume
#   vibe --resume <uuid>  # resume a specific Claude conversation by id
#   vibe --list           # list available projects
#   vibe --help           # show this help
#
# Note: --continue and --resume are opt-in. Default is fresh — the durable
# handover lives in TODO.md, CLAUDE.md, and Claude's auto-memory, not in
# resumed conversations (which accumulate compaction debt over weeks).

set -euo pipefail

# ── Configuration ─────────────────────────────────────────────────────────────
CONFIG_FILE="${VIBE_CONFIG:-$HOME/.vibe/config}"
TOKENS_FILE="$HOME/.vibe/tokens"
SKIPPED_FILE="$HOME/.vibe/skipped"
IMAGE_MARKER="$HOME/.vibe/.image-built"
IMAGE_TAG="vibe-dev:latest"

# Resolve DEVCONTAINER_DIR from this script's real location, following symlinks.
# ~/bin/vibe is a symlink that install.sh points at either ~/.vibe-src (curl
# installs) or a developer's in-place clone. Reading devcontainer/ from next to
# the resolved script means both modes work and `rm -rf ~/.vibe-src` is safe
# once a dev clone is in use.
_vibe_src="${BASH_SOURCE[0]:-$0}"
while [ -L "$_vibe_src" ]; do
  _vibe_dir="$(cd "$(dirname "$_vibe_src")" && pwd -P)"
  _vibe_src="$(readlink "$_vibe_src")"
  [[ "$_vibe_src" != /* ]] && _vibe_src="$_vibe_dir/$_vibe_src"
done
DEVCONTAINER_DIR="$(cd "$(dirname "$_vibe_src")" && pwd -P)/devcontainer"
unset _vibe_src _vibe_dir

if [ -f "$CONFIG_FILE" ]; then
  # shellcheck source=/dev/null
  source "$CONFIG_FILE"
fi

PROJECTS_DIR="${VIBE_PROJECTS_DIR:-$HOME/Projects}"

# ── Helpers ───────────────────────────────────────────────────────────────────
usage() {
  grep '^#' "$0" | grep -v '#!/' | sed 's/^# \?//'
  exit 0
}

require() {
  if ! command -v "$1" &>/dev/null; then
    echo "  ✗ '$1' not found. $2"
    exit 1
  fi
}

# Portable lowercase — avoids ${var,,} which requires bash 4+ (macOS ships bash 3.2)
lowercase() {
  tr '[:upper:]' '[:lower:]' <<< "$1"
}

# Three-way prompt: prints "yes", "no", or "never"
ask_yes_no_never() {
  local prompt="$1"
  local reply reply_lc
  while true; do
    read -rp "  $prompt [Y/n/never]: " reply
    reply="${reply:-y}"
    reply_lc=$(lowercase "$reply")
    case "$reply_lc" in
      y|yes)   echo "yes";   return ;;
      n|no)    echo "no";    return ;;
      never)   echo "never"; return ;;
      *) echo "  Please answer y, n, or never." ;;
    esac
  done
}

ask_yes_no() {
  local prompt="$1" default="${2:-y}"
  local options reply reply_lc
  [ "$default" = "n" ] && options="y/N" || options="Y/n"
  read -rp "  $prompt [$options]: " reply
  reply="${reply:-$default}"
  reply_lc=$(lowercase "$reply")
  [ "$reply_lc" = "y" ]
}

# ── Git helpers ───────────────────────────────────────────────────────────────

detect_github_repo() {
  local url
  url=$(git remote get-url origin 2>/dev/null) || return 1
  if [[ "$url" =~ github\.com[:/]([^/]+/[^/.]+)(\.git)?$ ]]; then
    echo "${BASH_REMATCH[1]}"
    return 0
  fi
  return 1
}

is_github_skipped() {
  [ -f "$SKIPPED_FILE" ] || return 1
  grep -qxF "$WORKSPACE" "$SKIPPED_FILE"
}

mark_github_skipped() {
  mkdir -p "$(dirname "$SKIPPED_FILE")"
  echo "$WORKSPACE" >> "$SKIPPED_FILE"
  echo "  ✓ Got it — won't ask about GitHub for this project again."
}

ensure_initial_commit() {
  if ! git rev-parse --git-dir &>/dev/null; then
    echo "  Initialising git repository..."
    git init
  fi
  if ! git rev-parse HEAD &>/dev/null 2>&1; then
    git add -A 2>/dev/null || true
    git commit --allow-empty -m "Initial commit" 2>/dev/null || true
    echo "  ✓ Initial commit created."
  fi
}

create_github_repo() {
  echo ""
  echo "  No GitHub repo found for this project."
  echo ""

  local answer
  answer=$(ask_yes_no_never "Create a GitHub repo for it?")

  case "$answer" in
    never) mark_github_skipped; return ;;
    no)    echo "  Skipping — launching without GitHub."; return ;;
  esac

  local repo_name
  read -rp "  Repo name [$PROJECT_NAME]: " repo_name
  repo_name="${repo_name:-$PROJECT_NAME}"

  local visibility="private"
  ask_yes_no "Make it public?" n && visibility="public"

  local description=""
  read -rp "  Description (optional): " description

  ensure_initial_commit

  local gh_user
  gh_user=$(gh api user --jq '.login' 2>/dev/null) || {
    echo "  ✗ Not logged in to GitHub CLI. Run: gh auth login"
    return
  }

  echo "  Creating $visibility repo $gh_user/$repo_name on GitHub..."

  local create_args=("$repo_name" "--$visibility" "--source=." "--push")
  [ -n "$description" ] && create_args+=("--description=$description")

  if gh repo create "${create_args[@]}"; then
    GITHUB_REPO="$gh_user/$repo_name"
    echo "  ✓ Repo created: https://github.com/$GITHUB_REPO"
  else
    echo "  ✗ Repo creation failed — launching without GitHub."
  fi
}

# ── Token helpers ─────────────────────────────────────────────────────────────

lookup_token() {
  local repo="$1"
  [ -f "$TOKENS_FILE" ] || return 0
  grep "^${repo}=" "$TOKENS_FILE" 2>/dev/null | cut -d= -f2 || true
}

save_token() {
  local repo="$1" token="$2"
  mkdir -p "$(dirname "$TOKENS_FILE")"
  touch "$TOKENS_FILE"
  local tmp
  tmp=$(mktemp)
  grep -v "^${repo}=" "$TOKENS_FILE" > "$tmp" || true
  echo "${repo}=${token}" >> "$tmp"
  mv "$tmp" "$TOKENS_FILE"
  chmod 600 "$TOKENS_FILE"
}

setup_token() {
  local repo="$1"
  local repo_short="${repo#*/}"
  cat << MSG

  No GitHub token found for $repo.

  I'll open GitHub so you can create a fine-grained token.
  On that page:
    1. Give it a name, e.g.: vibe-$repo_short
    2. Set an expiry (90 days is a good default)
    3. Under 'Repository access' → 'Only select repositories'
       → choose $repo_short
    4. Under 'Permissions' enable:
         Contents        → Read and write
         Metadata        → Read-only  (auto-selected)
         Pull requests   → Read and write
    5. Click 'Generate token' and copy it

MSG
  read -rp "  Press Enter to open GitHub in your browser (or Ctrl+C to skip)..."
  open "https://github.com/settings/personal-access-tokens/new"
  echo ""
  read -rsp "  Paste your token (input is hidden): " input_token
  echo ""

  if [ -z "$input_token" ]; then
    echo "  No token entered — launching without GitHub auth."
    GITHUB_TOKEN=""
    return
  fi

  save_token "$repo" "$input_token"
  echo "  ✓ Token saved — you won't be asked again for this repo."
  GITHUB_TOKEN="$input_token"
}

# ── Docker config helpers ─────────────────────────────────────────────────────

# Disable Docker CLI's "What's next?" hints by setting features.hints="false"
# in ~/.docker/config.json. Idempotent. Respects an explicit user string
# choice, but coerces bool values (written by earlier vibe versions or older
# Docker releases) — current Docker CLI rejects non-string feature values
# and prints a WARNING on every invocation until fixed. Bails on malformed
# JSON rather than trampling the user's config.
ensure_docker_hints_off() {
  local cfg="$HOME/.docker/config.json"
  mkdir -p "$(dirname "$cfg")"
  if [ ! -f "$cfg" ] || [ ! -s "$cfg" ]; then
    printf '{\n  "features": {\n    "hints": "false"\n  }\n}\n' > "$cfg"
    return
  fi
  python3 - "$cfg" << 'PY'
import json, sys
path = sys.argv[1]
try:
    with open(path) as f:
        original = f.read()
    cfg = json.loads(original)
except (json.JSONDecodeError, OSError, ValueError):
    sys.exit(0)

features = cfg.get("features")
if not isinstance(features, dict):
    features = {}
    cfg["features"] = features

for k, v in list(features.items()):
    if isinstance(v, bool):
        features[k] = "true" if v else "false"

if not isinstance(features.get("hints"), str):
    features["hints"] = "false"

new = json.dumps(cfg, indent=2) + "\n"
if new != original:
    with open(path, "w") as f:
        f.write(new)
PY
}

# ── Claude-invocation builder ─────────────────────────────────────────────────
# Echoes the resume-related arg fragment to prepend to claude's argv based on
# CONTINUE / RESUME / RESUME_UID. Empty string for fresh launch. Defined here
# (above the VIBE_SOURCE_ONLY guard) so smoke-test.py can exercise it.
build_claude_resume_args() {
  if [ "${CONTINUE:-false}" = "true" ]; then
    echo "--continue"
  elif [ "${RESUME:-false}" = "true" ]; then
    if [ -n "${RESUME_UID:-}" ]; then
      echo "--resume $RESUME_UID"
    else
      echo "--resume"
    fi
  fi
}

# Returns 0 if the argument is a UUID (8-4-4-4-12 hex), 1 otherwise. Used by
# the flag parser to decide whether the token after --resume is a session id
# (consume it) or the next flag / project name (leave it for later parsing).
is_uuid() {
  [[ "${1:-}" =~ ^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$ ]]
}

# Allow smoke-test.py to source this file for pure unit-testing of helpers
# without running the main launch logic below.
[ "${VIBE_SOURCE_ONLY:-}" = "1" ] && return 0 2>/dev/null

# ── Flags ─────────────────────────────────────────────────────────────────────
REBUILD=false
CONTINUE=false
RESUME=false
RESUME_UID=""
while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --rebuild) REBUILD=true; shift ;;
    --continue) CONTINUE=true; shift ;;
    --resume)
      RESUME=true; shift
      if is_uuid "${1:-}"; then
        RESUME_UID="$1"; shift
      fi
      ;;
    --list)
      echo "Projects in $PROJECTS_DIR:"
      ls "$PROJECTS_DIR"
      exit 0
      ;;
    --help|-h) usage ;;
    *) echo "Unknown flag: $1"; exit 1 ;;
  esac
done

if [ "$CONTINUE" = true ] && [ "$RESUME" = true ]; then
  echo "  ✗ --continue and --resume are mutually exclusive."
  exit 1
fi

# ── Resolve workspace ─────────────────────────────────────────────────────────
if [ "$#" -eq 0 ]; then
  WORKSPACE="$(pwd)"
  PROJECT_NAME="$(basename "$WORKSPACE")"
else
  PROJECT_NAME="$1"
  if [ -d "$PROJECT_NAME" ]; then
    WORKSPACE="$(cd "$PROJECT_NAME" && pwd)"
    PROJECT_NAME="$(basename "$WORKSPACE")"
  else
    WORKSPACE="$PROJECTS_DIR/$PROJECT_NAME"
    if [ ! -d "$WORKSPACE" ]; then
      echo "  Error: Project not found: $WORKSPACE"
      echo ""
      echo "  Available projects:"
      ls "$PROJECTS_DIR"
      exit 1
    fi
  fi
fi

# ── Preflight ─────────────────────────────────────────────────────────────────
require docker       "Install OrbStack (https://orbstack.dev) or Docker Desktop."
require devcontainer "Install with: npm install -g @devcontainers/cli"
require gh           "Install from: https://cli.github.com"

# Suppress Docker Desktop's "What's next? Try Docker Debug..." hint.
# DOCKER_CLI_HINTS=false is the documented mechanism but doesn't always
# propagate through the devcontainer CLI to its docker subprocesses, so we
# also persist the setting in ~/.docker/config.json.
export DOCKER_CLI_HINTS=false
ensure_docker_hints_off

if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
  echo "  ⚠  ANTHROPIC_API_KEY is set — Claude Code inside the container would bill"
  echo "     against API credits if it honoured it. vibe forces subscription auth via"
  echo "     settings.local.json (forceLoginMethod=claudeai), so this should be"
  echo "     ignored — but unset it in your host env for good measure."
  echo ""
fi

if [ ! -f "$DEVCONTAINER_DIR/devcontainer.json" ]; then
  echo "  ✗ vibe source not found at $DEVCONTAINER_DIR"
  echo "    Run the installer:"
  echo "      bash <(curl -fsSL https://raw.githubusercontent.com/Aqueum/vibe/main/install.sh)"
  exit 1
fi

# devcontainer.json bind-mounts ~/.ssh and ~/.gitconfig into the container.
# On a fresh Mac neither may exist yet, which makes the bind mount fail hard.
# Create them eagerly with the permissions SSH tools would set anyway.
if [ ! -d "$HOME/.ssh" ]; then
  mkdir -p "$HOME/.ssh"
  chmod 700 "$HOME/.ssh"
fi
[ -f "$HOME/.gitconfig" ] || touch "$HOME/.gitconfig"

# ── GitHub setup ──────────────────────────────────────────────────────────────
GITHUB_TOKEN=""
GITHUB_REPO=""
cd "$WORKSPACE"

if is_github_skipped; then
  : # silently skip — user said never
elif GITHUB_REPO=$(detect_github_repo); then
  GITHUB_TOKEN=$(lookup_token "$GITHUB_REPO")
  if [ -z "$GITHUB_TOKEN" ]; then
    setup_token "$GITHUB_REPO"
  fi
else
  create_github_repo
  if [ -n "$GITHUB_REPO" ]; then
    setup_token "$GITHUB_REPO"
  fi
fi

# ── Build the image if missing, stale, or --rebuild ──────────────────────────
# Auto-rebuild when any file in $DEVCONTAINER_DIR is newer than $IMAGE_MARKER
# (touched after each successful build). Catches updated Dockerfile, firewall
# script, etc. after `install.sh` or manual edits without needing --rebuild.
if [ "$REBUILD" != true ] && docker image inspect "$IMAGE_TAG" >/dev/null 2>&1; then
  if [ ! -f "$IMAGE_MARKER" ] \
     || [ -n "$(find "$DEVCONTAINER_DIR" -type f -newer "$IMAGE_MARKER" -print 2>/dev/null | head -n 1)" ]; then
    echo "  devcontainer/ changed since last build — rebuilding image."
    REBUILD=true
  fi
fi

if [ "$REBUILD" = true ] || ! docker image inspect "$IMAGE_TAG" >/dev/null 2>&1; then
  echo "  Building vibe container image ($IMAGE_TAG)..."
  docker build -t "$IMAGE_TAG" "$DEVCONTAINER_DIR"
  mkdir -p "$(dirname "$IMAGE_MARKER")"
  touch "$IMAGE_MARKER"
fi

# ── Write persistent session settings ────────────────────────────────────────
# settings.local.json is read by Claude Code at startup. Written fresh on every
# launch so these settings are always in effect regardless of how the project
# was cloned or whether the file existed before.
#
#   permissions.defaultMode bypassPermissions — YOLO mode (no approval prompts)
#   forceLoginMethod claudeai                 — use Claude Pro/Max subscription,
#                                               not an API key
#   hooks                                     — tool-call backstop: PreToolUse
#                                               blocks history-overwriting
#                                               force-push; Stop/Notification
#                                               ring the terminal bell so the
#                                               outer terminal tab badges when
#                                               Claude goes idle or needs input
mkdir -p "$WORKSPACE/.claude"
cat > "$WORKSPACE/.claude/settings.local.json" << 'EOF'
{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "forceLoginMethod": "claudeai",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "/usr/local/bin/guard-bash.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "printf '\\a' >&2" }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "printf '\\a' >&2" }
        ]
      }
    ]
  }
}
EOF

# Keep settings.local.json out of git (it's personal/session config).
if [ -f "$WORKSPACE/.gitignore" ]; then
  if ! grep -qF ".claude/settings.local.json" "$WORKSPACE/.gitignore"; then
    echo ".claude/settings.local.json" >> "$WORKSPACE/.gitignore"
  fi
fi

# ── Launch via devcontainer CLI ──────────────────────────────────────────────
# export so ${localEnv:GITHUB_TOKEN} in devcontainer.json resolves in this env.
export GITHUB_TOKEN

echo ""
if [ "$CONTINUE" = true ]; then
  echo "  ↻ vibe session continuing (most recent Claude conversation)"
elif [ "$RESUME" = true ] && [ -n "$RESUME_UID" ]; then
  echo "  ↻ vibe session resuming (Claude session ${RESUME_UID:0:8}…)"
elif [ "$RESUME" = true ]; then
  echo "  ↻ vibe session resuming (Claude conversation picker)"
else
  echo "  🚀 vibe session starting"
fi
echo "     project : $PROJECT_NAME"
echo "     path    : $WORKSPACE"
[ -n "$GITHUB_REPO" ] && echo "     github  : $GITHUB_REPO"
echo "     hooks   : tool-call guards + idle bell"
echo "     extras  : /diet · /feast · /vs · shellcheck-fixer · security-review"
echo ""

UP_BASE_ARGS=(
  up
  --workspace-folder "$WORKSPACE"
  --override-config "$DEVCONTAINER_DIR/devcontainer.json"
)
UP_ARGS=("${UP_BASE_ARGS[@]}")
[ "$REBUILD" = true ] && UP_ARGS+=(--remove-existing-container)

# If `devcontainer up` fails, the postStartCommand likely died mid-way (e.g.
# init-firewall.sh bombed out), leaving a container that's running but only
# partially configured — dangerous, because the next `vibe` invocation would
# skip postStart entirely and silently use a half-locked-down firewall.
# Retry once with --remove-existing-container to get a clean state. If that
# still fails, surface the error rather than hide it.
if ! devcontainer "${UP_ARGS[@]}"; then
  echo ""
  echo "  ⚠  postStartCommand failed — container is in a partial state."
  echo "     Removing it and retrying once with a fresh container."
  echo ""
  if ! devcontainer "${UP_BASE_ARGS[@]}" --remove-existing-container; then
    echo ""
    echo "  ✗ Retry also failed. Fix the underlying error above and re-run."
    echo "    If the image itself is suspect: vibe --rebuild"
    exit 1
  fi
fi

# Start claude with a clean, deterministic shell env:
#   - `bash --noprofile --norc` — launcher shell sources no rc files
#   - `env SHELL=/bin/bash` — Claude Code's env-snapshot subprocess spawns
#     non-interactive bash (reads no rc), not the image's default zsh
#   - `LC_ALL=C.UTF-8 LANG=C.UTF-8` — silences the bash "locale not supported"
#     warning when the host inherits en_US.UTF-8 (and neutralises any older
#     image whose zsh-in-docker .zshrc re-exports it before the Dockerfile sed)
#
# Note: a stray "p" sometimes seen before the banner is NOT a shell-rc leak —
# it's Apple Terminal.app's VT parser mishandling claude's `\e[?2026$p` DECRQM
# (synchronized-output) probe and echoing the `p` terminator. Outer-terminal
# bug; switch to iTerm2 / Ghostty / Kitty / Alacritty to avoid it.
# `exec` replaces bash with claude so signals go straight to claude.
# build_claude_resume_args echoes "" / "--continue" / "--resume" / "--resume <uuid>".
# RESUME_UID is restricted to UUID format by is_uuid in the parser, so embedding
# it in the command string is injection-safe.
CLAUDE_RESUME_ARGS=$(build_claude_resume_args)
devcontainer exec \
  --workspace-folder "$WORKSPACE" \
  --override-config "$DEVCONTAINER_DIR/devcontainer.json" \
  /bin/bash --noprofile --norc -c "exec env SHELL=/bin/bash LC_ALL=C.UTF-8 LANG=C.UTF-8 claude ${CLAUDE_RESUME_ARGS:+$CLAUDE_RESUME_ARGS }--permission-mode bypassPermissions"
