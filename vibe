#!/bin/bash
# vibe — a thin wrapper around ClaudeBox for per-project YOLO vibe coding sessions
# https://github.com/Aqueum/vibe
#
# Usage:
#   vibe                  # cd to your project folder, then just run this
#   vibe <project-name>   # launch by name from anywhere (uses VIBE_PROJECTS_DIR)
#   vibe --rebuild        # force rebuild of ClaudeBox image
#   vibe --list           # list available projects
#   vibe --help           # show this help

set -euo pipefail

# ── Configuration ─────────────────────────────────────────────────────────────
CONFIG_FILE="${VIBE_CONFIG:-$HOME/.vibe/config}"
TOKENS_FILE="$HOME/.vibe/tokens"
SKIPPED_FILE="$HOME/.vibe/skipped"

if [ -f "$CONFIG_FILE" ]; then
  # shellcheck source=/dev/null
  source "$CONFIG_FILE"
fi

PROJECTS_DIR="${VIBE_PROJECTS_DIR:-$HOME/Projects}"

# ── Helpers ───────────────────────────────────────────────────────────────────
usage() {
  grep '^#' "$0" | grep -v '#!/' | sed 's/^# \?//'
  exit 0
}

require() {
  if ! command -v "$1" &>/dev/null; then
    echo "  ✗ '$1' not found. $2"
    exit 1
  fi
}

# Portable lowercase — avoids ${var,,} which requires bash 4+ (macOS ships bash 3.2)
lowercase() {
  tr '[:upper:]' '[:lower:]' <<< "$1"
}

# Detect paths that would generate an invalid Docker image tag via claudebox.
# Docker allows _ and __ as separators but rejects ___ or longer runs.
# A path like "my - project" sanitises to "my___project" (space-hyphen-space → ___),
# which Docker's reference parser rejects as an invalid tag format.
validate_docker_tag_from_path() {
  local path="$1"
  local sanitized
  # Mirror claudebox: lowercase then replace every non-alphanumeric char with _
  sanitized=$(printf '%s' "$path" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9' '_')
  # Three or more consecutive underscores are rejected by Docker's reference parser
  printf '%s' "$sanitized" | grep -q '___' && return 1
  return 0
}

# Three-way prompt: prints "yes", "no", or "never"
ask_yes_no_never() {
  local prompt="$1"
  local reply reply_lc
  while true; do
    read -rp "  $prompt [Y/n/never]: " reply
    reply="${reply:-y}"
    reply_lc=$(lowercase "$reply")
    case "$reply_lc" in
      y|yes)   echo "yes";   return ;;
      n|no)    echo "no";    return ;;
      never)   echo "never"; return ;;
      *) echo "  Please answer y, n, or never." ;;
    esac
  done
}

ask_yes_no() {
  local prompt="$1" default="${2:-y}"
  local options reply reply_lc
  [ "$default" = "n" ] && options="y/N" || options="Y/n"
  read -rp "  $prompt [$options]: " reply
  reply="${reply:-$default}"
  reply_lc=$(lowercase "$reply")
  [ "$reply_lc" = "y" ]
}

# ── Git helpers ───────────────────────────────────────────────────────────────

detect_github_repo() {
  local url
  url=$(git remote get-url origin 2>/dev/null) || return 1
  if [[ "$url" =~ github\.com[:/]([^/]+/[^/.]+)(\.git)?$ ]]; then
    echo "${BASH_REMATCH[1]}"
    return 0
  fi
  return 1
}

is_github_skipped() {
  [ -f "$SKIPPED_FILE" ] || return 1
  grep -qxF "$WORKSPACE" "$SKIPPED_FILE"
}

mark_github_skipped() {
  mkdir -p "$(dirname "$SKIPPED_FILE")"
  echo "$WORKSPACE" >> "$SKIPPED_FILE"
  echo "  ✓ Got it — won't ask about GitHub for this project again."
}

ensure_initial_commit() {
  if ! git rev-parse --git-dir &>/dev/null; then
    echo "  Initialising git repository..."
    git init
  fi
  if ! git rev-parse HEAD &>/dev/null 2>&1; then
    git add -A 2>/dev/null || true
    git commit --allow-empty -m "Initial commit" 2>/dev/null || true
    echo "  ✓ Initial commit created."
  fi
}

create_github_repo() {
  echo ""
  echo "  No GitHub repo found for this project."
  echo ""

  local answer
  answer=$(ask_yes_no_never "Create a GitHub repo for it?")

  case "$answer" in
    never) mark_github_skipped; return ;;
    no)    echo "  Skipping — launching without GitHub."; return ;;
  esac

  local repo_name
  read -rp "  Repo name [$PROJECT_NAME]: " repo_name
  repo_name="${repo_name:-$PROJECT_NAME}"

  local visibility="private"
  ask_yes_no "Make it public?" n && visibility="public"

  local description=""
  read -rp "  Description (optional): " description

  ensure_initial_commit

  local gh_user
  gh_user=$(gh api user --jq '.login' 2>/dev/null) || {
    echo "  ✗ Not logged in to GitHub CLI. Run: gh auth login"
    return
  }

  echo "  Creating $visibility repo $gh_user/$repo_name on GitHub..."

  local create_args=("$repo_name" "--$visibility" "--source=." "--push")
  [ -n "$description" ] && create_args+=("--description=$description")

  if gh repo create "${create_args[@]}"; then
    GITHUB_REPO="$gh_user/$repo_name"
    echo "  ✓ Repo created: https://github.com/$GITHUB_REPO"
  else
    echo "  ✗ Repo creation failed — launching without GitHub."
  fi
}

# ── Token helpers ─────────────────────────────────────────────────────────────

lookup_token() {
  local repo="$1"
  [ -f "$TOKENS_FILE" ] || return 0
  grep "^${repo}=" "$TOKENS_FILE" 2>/dev/null | cut -d= -f2 || true
}

save_token() {
  local repo="$1" token="$2"
  mkdir -p "$(dirname "$TOKENS_FILE")"
  touch "$TOKENS_FILE"
  local tmp
  tmp=$(mktemp)
  grep -v "^${repo}=" "$TOKENS_FILE" > "$tmp" || true
  echo "${repo}=${token}" >> "$tmp"
  mv "$tmp" "$TOKENS_FILE"
  chmod 600 "$TOKENS_FILE"
}

setup_token() {
  local repo="$1"
  local repo_short="${repo#*/}"
  cat << MSG

  No GitHub token found for $repo.

  I'll open GitHub so you can create a fine-grained token.
  On that page:
    1. Give it a name, e.g.: vibe-$repo_short
    2. Set an expiry (90 days is a good default)
    3. Under 'Repository access' → 'Only select repositories'
       → choose $repo_short
    4. Under 'Permissions' enable:
         Contents        → Read and write
         Metadata        → Read-only  (auto-selected)
         Pull requests   → Read and write
    5. Click 'Generate token' and copy it

MSG
  read -rp "  Press Enter to open GitHub in your browser (or Ctrl+C to skip)..."
  open "https://github.com/settings/personal-access-tokens/new"
  echo ""
  read -rsp "  Paste your token (input is hidden): " input_token
  echo ""

  if [ -z "$input_token" ]; then
    echo "  No token entered — launching without GitHub auth."
    GITHUB_TOKEN=""
    return
  fi

  save_token "$repo" "$input_token"
  echo "  ✓ Token saved — you won't be asked again for this repo."
  GITHUB_TOKEN="$input_token"
}

# ── ClaudeBox slot helpers ────────────────────────────────────────────────────

# Cache claudebox slots output to avoid repeated subprocess calls.
# Each `claudebox slots` invocation spawns a Docker query; caching lets the
# three helpers below grep an in-memory string instead.
SLOT_CACHE=""
refresh_slot_cache() {
  SLOT_CACHE=$(claudebox slots 2>/dev/null) || true
}

# Returns true if there's at least one authenticated (but not unauthenticated) slot.
# "Authenticated" has capital A; "Unauthenticated" has lowercase a — case-sensitive
# grep correctly distinguishes them.
has_authenticated_slot() {
  grep -q "Authenticated" <<< "$SLOT_CACHE"
}

# Returns true if any slot has an actively running container.
# "Active" has capital A; "Inactive" has lowercase a — same trick applies.
has_active_session() {
  grep -q "Active" <<< "$SLOT_CACHE"
}

# Returns true if there's an authenticated slot that isn't currently running.
# This means claudebox can start a new session without creating a new slot.
has_idle_authenticated_slot() {
  grep "Authenticated" <<< "$SLOT_CACHE" | grep -q "Inactive"
}

# Authenticates a slot, reusing an existing unauthenticated one if available
# rather than always creating a new one.
setup_claudebox_slot() {
  cat <<'  MSG'

  ────────────────────────────────────────────────────────────────
  Setting up a Claude container slot.
  ────────────────────────────────────────────────────────────────

  MSG

  # Prefer reusing an existing unauthenticated slot over creating a new one.
  local target_slot
  target_slot=$(awk '/Unauthenticated/ {print $1; exit}' <<< "$SLOT_CACHE") || true

  if [ -n "$target_slot" ]; then
    echo "  Reusing existing slot $target_slot."
    echo ""
  else
    echo "  Step 1/2: Creating container slot..."
    claudebox create
    echo ""
    refresh_slot_cache
    target_slot=$(awk '/Unauthenticated/ {print $1; exit}' <<< "$SLOT_CACHE") || true
    target_slot="${target_slot:-1}"
  fi

  cat << MSG
  Authenticate with your Claude Pro/Max account.

  ⚠  The browser won't open automatically from inside Docker.
     When you see the login URL, copy it and paste it into
     your browser. After logging in, type 'exit' to return here.

MSG
  read -rp "  Press Enter to open slot $target_slot for authentication..."
  echo ""
  claudebox slot "$target_slot" || true   # user authenticates then types exit

  echo ""
  refresh_slot_cache
  if has_authenticated_slot; then
    echo "  ✓ Authenticated — launching your vibe session now."
    echo ""
  else
    cat << MSG
  ⚠  No authenticated slot found.
     If you didn't finish, run:  claudebox slot $target_slot
     Then run vibe again.
MSG
    exit 1
  fi
}

# ── Flags ─────────────────────────────────────────────────────────────────────
REBUILD=false
while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --rebuild) REBUILD=true; shift ;;
    --list)
      echo "Projects in $PROJECTS_DIR:"
      ls "$PROJECTS_DIR"
      exit 0
      ;;
    --help|-h) usage ;;
    *) echo "Unknown flag: $1"; exit 1 ;;
  esac
done

# ── Resolve workspace ─────────────────────────────────────────────────────────
if [ "$#" -eq 0 ]; then
  WORKSPACE="$(pwd)"
  PROJECT_NAME="$(basename "$WORKSPACE")"
else
  PROJECT_NAME="$1"
  if [ -d "$PROJECT_NAME" ]; then
    WORKSPACE="$(cd "$PROJECT_NAME" && pwd)"
    PROJECT_NAME="$(basename "$WORKSPACE")"
  else
    WORKSPACE="$PROJECTS_DIR/$PROJECT_NAME"
    if [ ! -d "$WORKSPACE" ]; then
      echo "  Error: Project not found: $WORKSPACE"
      echo ""
      echo "  Available projects:"
      ls "$PROJECTS_DIR"
      exit 1
    fi
  fi
fi

# ── Checks ────────────────────────────────────────────────────────────────────
require claudebox "Install from: https://github.com/RchGrav/claudebox"

if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
  echo "  ⚠  ANTHROPIC_API_KEY is set — Claude Code will bill against your API credits."
  echo "     Unset it to use your Pro/Max subscription instead."
  echo ""
fi

# ── Pre-flight: validate workspace path ───────────────────────────────────────
if ! validate_docker_tag_from_path "$WORKSPACE"; then
  # Suggest a cleaner folder name: replace spaces with hyphens, squeeze runs of hyphens
  suggested=$(basename "$WORKSPACE" | tr ' ' '-' | tr -s '-')
  echo ""
  echo "  ✗ Your project path would generate an invalid Docker image name."
  echo ""
  echo "     $WORKSPACE"
  echo ""
  echo "  Docker rejects names with three or more consecutive underscores (___), which"
  echo "  occur when a folder name contains sequences like \" - \" (space-hyphen-space)."
  echo ""
  echo "  Rename the folder to fix this — for example:"
  echo "    $(basename "$WORKSPACE")  →  $suggested"
  echo ""
  exit 1
fi

# ── GitHub setup ──────────────────────────────────────────────────────────────
GITHUB_TOKEN=""
GITHUB_REPO=""
cd "$WORKSPACE"

if is_github_skipped; then
  : # silently skip — user said never
elif GITHUB_REPO=$(detect_github_repo); then
  GITHUB_TOKEN=$(lookup_token "$GITHUB_REPO")
  if [ -z "$GITHUB_TOKEN" ]; then
    setup_token "$GITHUB_REPO"
  fi
else
  create_github_repo
  if [ -n "$GITHUB_REPO" ]; then
    setup_token "$GITHUB_REPO"
  fi
fi

# ── ClaudeBox slot check ──────────────────────────────────────────────────────
refresh_slot_cache
if has_idle_authenticated_slot; then
  : # An idle authenticated slot is available — claudebox will use it.
elif has_authenticated_slot; then
  # Every authenticated slot is currently active (busy).
  echo "  ℹ  All Claude slots are busy for this project."
  echo ""
  if ask_yes_no "Open a new parallel slot?" y; then
    setup_claudebox_slot
  else
    echo "  Exiting — existing sessions are still running."
    exit 0
  fi
else
  # No authenticated slots exist — create and authenticate one.
  setup_claudebox_slot
fi

# ── Configure git credentials for the container ──────────────────────────────
# git doesn't read GITHUB_TOKEN automatically. Install a per-repo credential
# helper that reads it from the environment, so git push/pull work inside the
# container without a separate auth step. The helper is a no-op when
# GITHUB_TOKEN is unset, so normal git usage outside vibe is unaffected.
if [ -n "$GITHUB_TOKEN" ]; then
  git -C "$WORKSPACE" config --local credential.helper \
    '!f() { [ -n "$GITHUB_TOKEN" ] && printf "username=x\npassword=%s\n" "$GITHUB_TOKEN"; }; f'
fi

# ── Write persistent session settings ────────────────────────────────────────
# settings.local.json is read by Claude Code at startup. We write it fresh on
# every launch so these settings are always in effect regardless of how the
# project was cloned or whether the file existed before.
#
#   permissions.defaultMode bypassPermissions — YOLO mode (no approval prompts)
#   forceLoginMethod claudeai                 — use Claude Pro/Max subscription,
#                                               not an API key
mkdir -p "$WORKSPACE/.claude"
cat > "$WORKSPACE/.claude/settings.local.json" << 'EOF'
{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "forceLoginMethod": "claudeai"
}
EOF

# Keep settings.local.json out of git (it's personal/session config).
if [ -f "$WORKSPACE/.gitignore" ]; then
  if ! grep -qF ".claude/settings.local.json" "$WORKSPACE/.gitignore"; then
    echo ".claude/settings.local.json" >> "$WORKSPACE/.gitignore"
  fi
fi

# ── Launch ────────────────────────────────────────────────────────────────────
echo ""
echo "  🚀 vibe session starting"
echo "     project : $PROJECT_NAME"
echo "     path    : $WORKSPACE"
[ -n "$GITHUB_REPO" ] && echo "     github  : $GITHUB_REPO"
echo ""

CLAUDEBOX_ARGS=(--dangerously-skip-permissions)
[ "$REBUILD" = true ] && CLAUDEBOX_ARGS+=(--rebuild)

if [ -n "$GITHUB_TOKEN" ]; then
  GITHUB_TOKEN="$GITHUB_TOKEN" claudebox "${CLAUDEBOX_ARGS[@]}"
else
  claudebox "${CLAUDEBOX_ARGS[@]}"
fi
