+# smoke-test can stub it after sourcing, mirroring the existing docker()
+# stub precedent. Every failure mode is swallowed (`|| true`) — the
+# container may already be gone, or claude may have already exited. MUST
+# stay a literal, bare, non-`exec`-prefixed `devcontainer exec` invocation:
+# this is the surviving bare `devcontainer exec` line that keeps
+# test_vibe_final_line_no_exec's assertion (b) passing now that
+# launch_claude's body below is `exec devcontainer exec ...` (assertion a).
+vibe_container_kill_claude() {
+  devcontainer exec --workspace-folder "$WORKSPACE" --override-config "$OVERRIDE_CONFIG" pkill -TERM -x claude || true
+}
+
+# _vibe_stall_armed <marker_file> <ref_file> — kill-gate conditions 1+2 (see
+# vibe_stall_watchdog): marker active=1 AND either the literal relaunch
+# sentinel "-" (unconditional arm) or a non-empty, existing session-start ref
+# file that the marker is newer than (portable POSIX `-nt`, no stat -c/-f).
+# An empty or missing ref never arms (mktemp-failure fail-safe). Split out
+# from auto_resume_stalled (condition 3) so the watchdog can re-check the
+# cheap conditions first without a fresh heartbeat read every retry.
+_vibe_stall_armed() {
+  local marker="$1" ref="$2"
+  [ "$(auto_resume_field "$marker" active)" = "1" ] || return 1
+  [ "$ref" = "-" ] && return 0
+  [ -n "$ref" ] && [ -f "$ref" ] && [ "$marker" -nt "$ref" ]
+}
+
+# vibe_stall_watchdog <claude_pid> <marker_file> <hb_file> <ref_file> —
+# backgrounded by launch_claude_supervised alongside claude. Polls every
+# ${VIBE_STALL_POLL_SECS:-60}s while claude is alive (kill -0). On the first
+# poll where all three kill-gate conditions hold (_vibe_stall_armed plus a
+# stale heartbeat via auto_resume_stalled, default threshold 1800s): prints a
+# loud stderr warning (bell + threshold + cancel instruction), sleeps
+# ${VIBE_STALL_GRACE_SECS:-120}, re-checks all three conditions, and only if
+# STILL met kills in-container first (vibe_container_kill_claude), pauses
+# ${VIBE_STALL_KILL_PAUSE_SECS:-10} for that to land, then falls back to the
+# host client PID (`kill "$claude_pid"`) — never a host-side pkill. Either
+# way the function returns after handling this one escalation. All sleeps
+# are individually guarded so a signal or interrupted syscall can't trip
+# `set -e`; lifetime is bounded solely by claude-PID liveness, so an orphaned
+# watchdog (launcher died mid-wait) exits on its own within one poll interval.
+vibe_stall_watchdog() {
+  local claude_pid="$1" marker="$2" hb="$3" ref="$4"
+  local poll="${VIBE_STALL_POLL_SECS:-60}"
+  local grace="${VIBE_STALL_GRACE_SECS:-120}"
+  local stall_secs="${VIBE_STALL_SECS:-1800}"
+  local kill_pause="${VIBE_STALL_KILL_PAUSE_SECS:-10}"
+
+  while kill -0 "$claude_pid" 2>/dev/null; do
+    sleep "$poll" 2>/dev/null || true
+    if _vibe_stall_armed "$marker" "$ref" \
+       && auto_resume_stalled "$hb" "$(date +%s)" "$stall_secs"; then
+      printf '\n  \a⚠  auto-resume: no activity for over %ss — assuming the usage-limit picker is stuck.\n' "$stall_secs" >&2
+      printf '     Waiting %ss then killing this claude window (delete .vss/auto-resume to cancel).\n' "$grace" >&2
+      sleep "$grace" 2>/dev/null || true
+      if _vibe_stall_armed "$marker" "$ref" \
+         && auto_resume_stalled "$hb" "$(date +%s)" "$stall_secs"; then
+        vibe_container_kill_claude
+        sleep "$kill_pause" 2>/dev/null || true
+        kill "$claude_pid" 2>/dev/null || true
+      fi
+      return 0
+    fi
+  done
+  return 0
+}
