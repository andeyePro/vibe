# Never commit tokens or personal config
.vibe/
*.tokens
.env
.env.*
.claude/settings.local.json

# macOS
.DS_Store

# Python bytecode (smoke-test.py + code-check.py)
__pycache__/
*.pyc

# /vs per-cycle artifacts (spec.md, progress.md, tasks.json stay tracked)
.vs/cycle-*/

# /vss + /vsss ephemeral state (.vss/sessions/*.md is the committed audit trail)
.vss/last-plan.md
