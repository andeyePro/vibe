# Never commit tokens or personal config
.vibe/
*.tokens
.env
.env.*
.claude/settings.local.json

# macOS
.DS_Store

# Python bytecode (smoke-test.py + code-check.py)
__pycache__/
*.pyc

# vibe.andeye.com site (site/) — build artifacts only; src stays tracked
site/node_modules/
site/dist/
site/.astro/
site-recovered/

# /vs per-cycle artifacts (spec.md, progress.md, tasks.json stay tracked)
.vs/cycle-*/

# /vss + /vsss ephemeral state (.vss/sessions/*.md is the committed audit trail)
.vss/last-plan.md
.vss/auto-resume
.vss/heartbeat*
.vss/rate-limit*

# >>> vibe-managed runtime exclusions (auto-added; do not edit body) >>>
# Files vibe writes to /workspace at runtime. Committing them
# leaks per-machine state into the repo (PR-review-noise risk).
# Opt out: set VIBE_AUTO_GITIGNORE=0 before container start, or
# delete this entire block (won't be re-added once removed).
.claude/settings.local.json
.vibe/
.vibe-signals/
# <<< vibe-managed <<<

# Claude Code agent worktrees (transient, harness-managed)
.claude/worktrees/

# per-project OpenProject opt-in marker (task_020) - always untracked
.vibe-allow-op
